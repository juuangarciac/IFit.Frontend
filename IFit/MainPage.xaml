<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IFit.MainPage"
             Shell.NavBarIsVisible="False">
    <ScrollView BackgroundColor="{StaticResource BackgroundPrimaryDark}">
        <!-- Main Grid -->
        <Grid Style="{StaticResource BasicGrid}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- Welcome Image -->
            <Grid Grid.Row="0"
                  HorizontalOptions="Center" >
                <Image Source="wordcloud.png" 
                       Aspect="AspectFit"/>
            </Grid>

            <!-- SignUp/SignIn Form -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title/Subtitle -->
                <Grid Grid.Row="0"
                      RowSpacing="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <Label Grid.Row="0"
                        Text="IFit"
                        HorizontalTextAlignment="Center"
                        TextColor="#FFD369"
                        FontFamily="Montserrat-Bold"
                        FontSize="32"
                        />
                    <Label Grid.Row="1"
                        Text=" Tu nuevo entrenador personal."
                        HorizontalTextAlignment="Center"
                        TextColor="WhiteSmoke"
                        FontFamily="Montserrat-Medium"
                        FontSize="20"/>

                    <Label Grid.Row="2"
                        Text=" Rutina, Progreso, Estilo."
                        HorizontalTextAlignment="Center"
                        TextColor="WhiteSmoke"
                        FontFamily="Montserrat-Medium"
                        FontSize="20"/>
                </Grid>

                <!-- SignUp/SignIn Buttons -->
                <Grid Grid.Row="1"
                       RowSpacing="10"
                       Margin="15, 15, 15, 45"
                       VerticalOptions="End">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- Registrarme -->
                    <Button Grid.Row="0"
                            Text="Registrarme"
                            Style="{StaticResource ButtonBold-XL-dark-white}"
                            Clicked="OnSignUpClicked"
                        ></Button>
                    
                    <!-- Iniciar sesion -->
                    <Button Grid.Row="1"
                            Text="Iniciar sesión"
                            Style="{StaticResource ButtonBold-XL-light}"
                            Clicked="OnSignInClicked"
                        ></Button>
                </Grid>
            </Grid>
        </Grid>
        </ScrollView>
</ContentPage>
