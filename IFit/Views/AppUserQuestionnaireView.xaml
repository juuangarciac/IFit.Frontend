<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"  
             xmlns:models="clr-namespace:IFit.Models.Dtos.Questionnaire"
             x:Class="IFit.Views.AppUserQuestionnaireView"
             Title="Cuestionario"
             Shell.NavBarIsVisible="False" 
             BackgroundColor="{StaticResource BackgroundPrimaryDark}">

    <ContentPage.BindingContext>
        <vm:AppUserQuestionnaireViewModel/>
    </ContentPage.BindingContext>

    <Grid BackgroundColor="{StaticResource BackgroundPrimaryDark}">

        <!-- Loading Overlay -->
        <Grid IsVisible="{Binding IsLoading}"
              BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
              ZIndex="999">
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                              Color="{StaticResource TertiaryColor}"
                              HeightRequest="60"
                              WidthRequest="60"
                              HorizontalOptions="Center"
                              VerticalOptions="Center"/>
        </Grid>

        <!-- Main Content -->
        <ScrollView ZIndex="1">
            <Grid Margin="15"
                  RowSpacing="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- Header -->
                    <RowDefinition Height="Auto" />
                    <!-- Question Title -->
                    <RowDefinition Height="*" />
                    <!-- Options -->
                    <RowDefinition Height="Auto" />
                    <!-- Error Message -->
                    <RowDefinition Height="Auto" />
                    <!-- Navigation Buttons -->
                </Grid.RowDefinitions>

                <!--Header -->
                <Grid Grid.Row="0"
                      ColumnSpacing="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Back Button (disabled by default in your ViewModel) -->
                    <Button Grid.Column="0"
                            HorizontalOptions="Start"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent"
                            ImageSource="arrow.png"
                            Command="{Binding GoBackCommand}"
                            IsEnabled="{Binding CanGoBack}"
                            Opacity="{Binding CanGoBack, Converter={StaticResource BoolToOpacityConverter}}" />

                    <!-- Center line / Questionnaire Name -->
                    <Label Grid.Column="1"
                           Text="{Binding QuestionnaireName}"
                           Style="{StaticResource label-h3-white}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />

                    <!-- Cancel button -->
                    <Button Grid.Column="2"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent"
                            ImageSource="cancel.svg"
                            Clicked="onCancelClicked" />
                </Grid>

                <!-- Question text -->
                <Label Grid.Row="1"
                       Text="{Binding QuestionText}"
                       Style="{StaticResource label-h1-white}"
                       Margin="0,20,0,10" />

                <!-- Options List -->
                <CollectionView Grid.Row="2"
                                ItemsSource="{Binding Options}"
                                SelectionMode="Single"
                                SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                                Margin="0,0,0,15">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:OptionDTO">
                            <Border StrokeThickness="2"
                                    Stroke="{DynamicResource BackgroundPrimaryLight}"
                                    BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                                    Margin="0,0,0,15">

                                <!-- Triggers para cambiar el estilo cuando está seleccionada -->
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=SelectedItem}"
                                                 Value="{Binding .}">
                                        <Setter Property="Stroke" Value="{StaticResource PrimaryColor}" />
                                        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColorDarkOpacity}" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                                </Border.StrokeShape>

                                <Border.Shadow>
                                    <Shadow Brush="{DynamicResource BackgroundPrimaryLight}"
                                            Opacity="0.35"
                                            Radius="{DynamicResource CornerRadiusRectangle}" />
                                </Border.Shadow>

                                <Grid Margin="10"
                                      BackgroundColor="Transparent">
                                    <Label Text="{Binding Text}"
                                           Style="{DynamicResource label-h1-white}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Error Message -->
                <Border Grid.Row="3"
                        IsVisible="{Binding HasError}"
                        BackgroundColor="#FFEBEE"
                        StrokeThickness="1"
                        Stroke="#F44336"
                        Padding="12"
                        Margin="0,0,0,15">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#C62828"
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />
                </Border>

                <!--Navigation Buttons -->
                <Grid Grid.Row="4"
                      ColumnSpacing="15"
                      Margin="0,5,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Next Button -->
                    <Button Grid.Column="1"
                            Text="{Binding NextButtonText}"
                            Style="{StaticResource ButtonBold-XL-dark-yellow}"
                            Command="{Binding GoNextCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            HorizontalOptions="Fill" />
                </Grid>
            </Grid>
        </ScrollView>

        <!-- ========== INPUT TEXT OVERLAY ========== -->
        <Grid IsVisible="{Binding RequiresTextInput}"
              BackgroundColor="#CC000000"
              ZIndex="998"
              Padding="20">

            <!-- Al hacer clic en el fondo oscuro, se cierra el overlay -->
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseInputCommand}" />
            </Grid.GestureRecognizers>

            <!-- Input Container (no se cierra al hacer clic aquí) -->
            <Border StrokeThickness="2"
                    Stroke="{DynamicResource BackgroundPrimaryLight}"
                    BackgroundColor="{DynamicResource PrimaryColorLightOpacity90}"
                    Padding="20"
                    VerticalOptions="Center"
                    MaximumWidthRequest="500">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                </Border.StrokeShape>

                <!-- Grid interno con GestureRecognizer para detener propagación del tap -->
                <Grid RowSpacing="10">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer />
                    </Grid.GestureRecognizers>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!-- Close button -->
                        <RowDefinition Height="Auto" />
                        <!-- Prompt Label -->
                        <RowDefinition Height="Auto" />
                        <!-- Text Entry -->
                        <RowDefinition Height="Auto" />
                        <!-- Save Button -->
                    </Grid.RowDefinitions>

                    <!-- Close button -->
                    <Label Grid.Row="0"
                           Text="✕"
                           FontSize="24"
                           TextColor="{StaticResource TextPrimaryColorLight}"
                           HorizontalOptions="End"
                           VerticalOptions="Start"
                           Padding="5">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CloseInputCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Prompt Label -->
                    <Label Grid.Row="1"
                           Text="{Binding SelectedOption.TextInputPrompt}"
                           Style="{DynamicResource label-h2-white}"
                           HorizontalTextAlignment="Center"
                           IsVisible="{Binding SelectedOption.TextInputPrompt, Converter={StaticResource StringNotNullOrEmptyConverter}}" />

                    <!-- Text Entry -->
                    <Border Grid.Row="2"
                            StrokeThickness="1"
                            Stroke="{StaticResource QuaternaryColor}"
                            BackgroundColor="{StaticResource BackgroundPrimaryDark}">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>

                        <Entry x:Name="AdditionalTextEntry"
                               Text="{Binding AdditionalText, Mode=TwoWay}"
                               Placeholder="{Binding SelectedOption.TextInputPlaceholder}"
                               PlaceholderColor="{StaticResource QuaternaryColor}"
                               TextColor="{StaticResource QuaternaryColor}"
                               BackgroundColor="Transparent"
                               HeightRequest="120"
                               MaxLength="500"
                               VerticalOptions="Start"
                               VerticalTextAlignment="Start"
                               IsSpellCheckEnabled="False"
                               IsTextPredictionEnabled="False"
                               HandlerChanged="OnEntryHandlerChanged"
                               Margin="10" />
                    </Border>

                    <!-- Save Button -->
                    <Button Grid.Row="3"
                            Text="Guardar"
                            Style="{StaticResource ButtonBold-XL-dark-yellow}"
                            Command="{Binding CloseInputCommand}"
                            HorizontalOptions="Fill"
                            Margin="0,10,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
