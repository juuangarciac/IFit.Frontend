<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:models="clr-namespace:IFit.Models.Dtos.Questionnaire"
             xmlns:components="clr-namespace:IFit.Views.Components"
             x:Class="IFit.Views.AppUserQuestionnaireView"
             Title="Cuestionario"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:AppUserQuestionnaireViewModel/>
    </ContentPage.BindingContext>

    <Grid>

        <!-- Loading Overlay -->
        <components:LoadingOverlay IsLoading="{Binding IsLoading}"
                                   Message="{Binding StatusMessage}"
                                   ZIndex="999"/>

        <!-- Main Content -->
        <ScrollView ZIndex="1">
            <Grid Padding="20,50,20,20" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: Header -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                    <Button Grid.Column="0"
                            BackgroundColor="Transparent"
                            ImageSource="arrow.png"
                            VerticalOptions="Center"
                            Command="{Binding GoBackCommand}" />

                    <Label Grid.Column="1"
                           Text="{Binding QuestionnaireName}"
                           Style="{StaticResource label-h3-white}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />

                    <Button Grid.Column="2"
                            BackgroundColor="Transparent"
                            ImageSource="cancel.svg"
                            VerticalOptions="Center"
                            Clicked="onCancelClicked" />
                </Grid>

                <!-- Row 1: Question text -->
                <Label Grid.Row="1"
                       Text="{Binding QuestionText}"
                       Style="{StaticResource label-h1-white}" />

                <!-- Row 2: Options List -->
                <CollectionView Grid.Row="2"
                                ItemsSource="{Binding Options}"
                                SelectionMode="Single"
                                SelectedItem="{Binding SelectedOption, Mode=TwoWay}">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:OptionDTO">
                            <Border StrokeThickness="0"
                                    Margin="0,0,0,8">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource BackgroundSecondaryDark}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource BackgroundPrimaryDark}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Grid Padding="12,10">
                                    <Label Text="{Binding Text}"
                                           Style="{StaticResource label-h2-white}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Row 3: Navigation Buttons -->
                <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="1"
                            Text="{Binding NextButtonText}"
                            Style="{StaticResource ButtonBold-XL-dark-yellow}"
                            Command="{Binding GoNextCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            HorizontalOptions="Fill" />
                </Grid>
            </Grid>
        </ScrollView>

        <!-- INPUT TEXT OVERLAY -->
        <Grid IsVisible="{Binding RequiresTextInput}"
              BackgroundColor="#CC000000"
              ZIndex="998"
              Padding="20">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseInputCommand}" />
            </Grid.GestureRecognizers>

            <Border StrokeThickness="0"
                    BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                    Padding="20"
                    VerticalOptions="Center"
                    MaximumWidthRequest="500">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <Grid RowSpacing="12">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer />
                    </Grid.GestureRecognizers>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Close button -->
                    <Label Grid.Row="0"
                           Text="✕"
                           FontSize="18"
                           TextColor="{StaticResource TextPrimaryColorLight}"
                           HorizontalOptions="End"
                           MinimumWidthRequest="36"
                           MinimumHeightRequest="36"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CloseInputCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Prompt Label -->
                    <Label Grid.Row="1"
                           Text="{Binding SelectedOption.TextInputPrompt}"
                           Style="{StaticResource label-h2-white}"
                           HorizontalTextAlignment="Center"
                           IsVisible="{Binding SelectedOption.TextInputPrompt, Converter={StaticResource StringNotNullOrEmptyConverter}}" />

                    <!-- Text Entry -->
                    <Border Grid.Row="2"
                            BackgroundColor="{StaticResource BackgroundPrimaryLight}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Entry x:Name="AdditionalTextEntry"
                               Text="{Binding AdditionalText, Mode=TwoWay}"
                               Placeholder="{Binding SelectedOption.TextInputPlaceholder}"
                               PlaceholderColor="{StaticResource BackgroundSecondaryDark}"
                               TextColor="{StaticResource BackgroundPrimaryDark}"
                               BackgroundColor="Transparent"
                               HeightRequest="120"
                               MaxLength="500"
                               VerticalOptions="Start"
                               VerticalTextAlignment="Start"
                               ReturnType="Done"
                               IsSpellCheckEnabled="False"
                               IsTextPredictionEnabled="False"
                               HandlerChanged="OnEntryHandlerChanged"
                               Margin="10" />
                    </Border>

                    <!-- Save Button -->
                    <Button Grid.Row="3"
                            Text="Guardar"
                            Style="{StaticResource ButtonBold-XL-dark-yellow}"
                            Command="{Binding SaveTextInputCommand}"
                            HorizontalOptions="Fill" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
