<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:IFit.Models"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="IFit.Views.ChatAIView"
             x:DataType="vm:ChatAIViewModel"
             Title="ChatAIView"
             Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <Grid Background="{StaticResource PremiumGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Back Button -->
            <Button Grid.Column="0"
                    HorizontalOptions="Start"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    ImageSource="arrow.png"
                    Clicked="BackToHome" />

            <!-- ifit logo -->
            <Image Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Source="ifit_logo_white.png"
                   HeightRequest="20"
                   WidthRequest="120"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Chat messages -->
        <ScrollView Grid.Row="1"
                    x:Name="ChatScrollView"
                    Padding="15,10">
            <CollectionView ItemsSource="{Binding Messages}"
                            x:Name="ChatCollectionView">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ChatMessage">
                        <Grid Margin="0,4">
                            <!-- Mensaje AI (izquierda) -->
                            <Frame IsVisible="{Binding IsAI}"
                   BackgroundColor="#1E1E2E"
                   BorderColor="Transparent"
                   CornerRadius="16"
                   Padding="12,8"
                   HorizontalOptions="Start"
                   Margin="0,0,60,0">
                                <Label Text="{Binding Text}"
                       TextColor="White"
                       FontSize="14" />
                            </Frame>

                            <!-- Mensaje usuario (derecha) -->
                            <Frame IsVisible="{Binding IsUser}"
                   BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                   BorderColor="Transparent"
                   CornerRadius="16"
                   Padding="12,8"
                   HorizontalOptions="End"
                   Margin="60,0,0,0">
                                <Label Text="{Binding Text}"
                       TextColor="White"
                       FontSize="14" />
                            </Frame>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

        <!-- Input area -->
        <Grid Grid.Row="2"
              Padding="15,10"
              ColumnSpacing="10"
              BackgroundColor="#1E1E2E">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    StrokeThickness="0">
                
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>

                <Entry Placeholder="Escribe tu mensaje..."
                   PlaceholderColor="#888"
                   TextColor="White"
                   BackgroundColor="#2E2E3E"
                   Text="{Binding UserInput}"
                   ReturnCommand="{Binding SendMessageCommand}"
                   VerticalOptions="Center" />
            </Border>
            
            <Button Grid.Column="1"
                    Text="Enviar"
                    BackgroundColor="{StaticResource TertiaryColor}"
                    TextColor="{StaticResource BackgroundSecondaryDark}"
                    CornerRadius="10"
                    Command="{Binding SendMessageCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
        </Grid>
    </Grid>
</ContentPage>
