<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:IFit.Models"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="IFit.Views.ChatAIView"
             x:DataType="vm:ChatAIViewModel"
             Title="ChatAIView"
             Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <Grid Background="{StaticResource PremiumGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    ImageSource="arrow.png"
                    Clicked="BackToHome" />

            <Image Grid.Column="0"
                   Grid.ColumnSpan="3"
                   Source="ifit_logo_white.png"
                   HeightRequest="20"
                   WidthRequest="120"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />

            <Button Grid.Column="2"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource TextPrimaryColorLight}"
                    FontSize="22"
                    Text="☰"
                    Command="{Binding TogglePanelCommand}" />
        </Grid>

        <!-- Chat messages -->
        <ScrollView Grid.Row="1"
                    x:Name="ChatScrollView"
                    Padding="15,10">
            <CollectionView ItemsSource="{Binding Messages}"
                            x:Name="ChatCollectionView">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ChatMessage">
                        <Grid Margin="0,6">

                            <!-- AI bubble (left) -->
                            <Grid IsVisible="{Binding IsAI}"
                                  HorizontalOptions="Start"
                                  Margin="0,0,60,0"
                                  ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Coach avatar -->
                                <Border Grid.Column="0"
                                        WidthRequest="32"
                                        HeightRequest="32"
                                        StrokeThickness="0"
                                        BackgroundColor="{StaticResource TertiaryColor}"
                                        VerticalOptions="End">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <Image Source="insignia_ifit.png"
                                           WidthRequest="18"
                                           HeightRequest="18"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <!-- AI message bubble -->
                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16,16,16,4" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Text}"
                                           Style="{StaticResource label-p-white}"
                                           Padding="12,10" />
                                </Border>
                            </Grid>

                            <!-- User bubble (right) -->
                            <Border IsVisible="{Binding IsUser}"
                                    StrokeThickness="0"
                                    BackgroundColor="{StaticResource TertiaryColor}"
                                    HorizontalOptions="End"
                                    Margin="60,0,0,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16,16,4,16" />
                                </Border.StrokeShape>
                                <Label Text="{Binding Text}"
                                       FontFamily="Montserrat-Medium"
                                       FontSize="14"
                                       TextColor="{StaticResource BackgroundPrimaryDark}"
                                       Padding="12,10" />
                            </Border>

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

        <!-- Input area -->
        <Grid Grid.Row="2"
              BackgroundColor="{StaticResource BackgroundPrimaryDark}"
              Padding="15,12"
              ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource BorderRectangleWhite}">
                <Entry Placeholder="Escribe a tu coach..."
                       PlaceholderColor="{StaticResource Gray400}"
                       TextColor="{StaticResource BackgroundPrimaryDark}"
                       BackgroundColor="Transparent"
                       Text="{Binding UserInput}"
                       ReturnCommand="{Binding SendMessageCommand}"
                       VerticalOptions="Center" />
            </Border>

            <Button Grid.Column="1"
                    Style="{StaticResource ButtonBold-XL-dark-yellow}"
                    Text="Enviar"
                    WidthRequest="90"
                    HeightRequest="52"
                    Command="{Binding SendMessageCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
        </Grid>

        <!-- Backdrop: oscurece el contenido y cierra el panel al tocar fuera -->
        <BoxView Grid.RowSpan="3"
                 IsVisible="{Binding IsPanelVisible}"
                 Color="{StaticResource PrimaryColorLightOpacity70}"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding TogglePanelCommand}" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Panel lateral de conversaciones -->
        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsPanelVisible}"
              HorizontalOptions="Start"
              WidthRequest="290"
              BackgroundColor="{StaticResource BackgroundPrimaryDark}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Cabecera del panel -->
            <Grid Grid.Row="0"
                  Padding="16,50,16,16"
                  BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                  RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0"
                       Text="Conversaciones"
                       Style="{StaticResource label-h2-white}"
                       VerticalOptions="Center" />

                <Button Grid.Row="0" Grid.Column="1"
                        Text="✕"
                        TextColor="{StaticResource TextPrimaryColorLight}"
                        BackgroundColor="Transparent"
                        FontSize="18"
                        Padding="0"
                        WidthRequest="36"
                        HeightRequest="36"
                        Command="{Binding TogglePanelCommand}" />

                <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        Text="+ Nueva conversación"
                        Style="{StaticResource ButtonBold-XL-yellow}"
                        HeightRequest="44"
                        Command="{Binding NewConversationCommand}" />
            </Grid>

            <!-- Lista de conversaciones -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Conversations}"
                            VerticalOptions="Fill">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ConversationSummary">
                        <Border StrokeThickness="0"
                                Margin="12,4"
                                BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ChatAIViewModel}}, Path=SelectConversationCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid Padding="12,10" RowSpacing="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Coach name + fecha -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Column="0"
                                           Text="{Binding Conversation.CoachName}"
                                           Style="{StaticResource label-h3-white}"
                                           LineBreakMode="TailTruncation" />

                                    <Label Grid.Column="1"
                                           Text="{Binding FormattedDate}"
                                           Style="{StaticResource label-p-white}"
                                           Opacity="0.5"
                                           VerticalOptions="Center"
                                           Margin="8,0,0,0" />
                                </Grid>

                                <!-- Preview del último mensaje -->
                                <Label Grid.Row="1"
                                       Text="{Binding PreviewText}"
                                       Style="{StaticResource label-p-white}"
                                       Opacity="0.6"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <Label Text="No hay conversaciones guardadas"
                           Style="{StaticResource label-p-white}"
                           Opacity="0.6"
                           HorizontalOptions="Center"
                           Margin="0,32,0,0" />
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

    </Grid>
</ContentPage>
