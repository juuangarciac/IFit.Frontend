<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             x:Class="IFit.Views.SignInPage"
             Title="SignInPage"
             Shell.NavBarIsVisible="False">
    <ContentPage.BindingContext>
        <vm:LoginViewModel />
    </ContentPage.BindingContext>
    <ScrollView BackgroundColor="{StaticResource BackgroundPrimaryDark}">
        <!-- Main Grid -->
        <Grid Style="{StaticResource BasicGrid}"
           HorizontalOptions="Fill"
           VerticalOptions="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <Grid Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Label>
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Iniciar sesión en" 
                               TextColor="{StaticResource TextPrimaryColorLight}"
                                FontFamily="MontserratBold"
                                FontSize="20"/>
                            <Span Text=" IFit"
                               TextColor="{StaticResource TertiaryColor}"
                                FontFamily="MontserratBold"
                                FontSize="20" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Button Grid.Column="1" 
                     BackgroundColor="Transparent"
                     ImageSource="cancel.svg"
                     Clicked="onCancelClicked" />
            </Grid>


            <!-- SignIn with Ifit account -->
            <Grid Grid.Row="1"
               Margin="15, 0, 15, 15"
               RowSpacing="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Username Entry -->
                <Border Grid.Row="0"
                      StrokeThickness="0"
                      BackgroundColor="{StaticResource BackgroundPrimaryLight}"
                      Padding="5, 5, 5, 5"
                      HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Border.Content>
                        <Entry Placeholder="Introduzca su nombre de usuario"
                             PlaceholderColor="{StaticResource TextPrimaryColorDark}"
                             FontFamily="Montserrat-Regular"
                             FontSize="16"
                             BackgroundColor="Transparent" 
                               Text="{Binding username}"/>
                    </Border.Content>
                </Border>

                <!-- Password Entry -->
                <Border Grid.Row="1"
                      StrokeThickness="0"
                      BackgroundColor="{StaticResource BackgroundPrimaryLight}"
                      Padding="5, 5, 5, 5"
                      HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Border.Content>
                        <Entry Placeholder="Introduzca su contraseña"
                             PlaceholderColor="{StaticResource TextPrimaryColorDark}"
                             FontFamily="Montserrat-Regular"
                             FontSize="16"
                             IsPassword="True"
                             BackgroundColor="Transparent" 
                               Text="{Binding password}"/>
                    </Border.Content>
                </Border>

                <!-- Forgotten password -->
                <Grid Grid.Row="2">
                    <Button 
                             BackgroundColor="Transparent"
                         />
                    <Label
                        HorizontalTextAlignment="Center"
                        VerticalTextAlignment="Center"
                        HorizontalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="¿Has olvidado tu contraseña?"
                                        FontFamily="Montserrat-Light"
                                        FontSize="14"
                                        TextColor="{StaticResource TextSecondaryColorLight}" 
                                        TextDecorations="Underline"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Grid>

                <Button Grid.Row="4"
                     Text="Iniciar sesión"
                     Style="{StaticResource ButtonBold-XL-yellow}"
                     CornerRadius="{StaticResource CornerRadiusRectangle}" 
                        Command="{Binding LoginCommand}"/>

            </Grid>

            <!-- SignIn with Third party services -->
            <Grid Grid.Row="2"
               Margin="15, 0, 15, 15"
               RowSpacing="15">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      ColumnSpacing="20"
                      Padding="20,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Línea izquierda -->
                    <BoxView Grid.Column="0"
                             HeightRequest="1"
                             BackgroundColor="{StaticResource TextSecondaryColorLight}"
                             VerticalOptions="Center" />

                    <!-- Texto central -->
                    <Label Grid.Column="1"
                           Text="O"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           FontFamily="Montserrat-Light"
                           FontSize="16"
                           TextColor="{StaticResource TextSecondaryColorLight}" />

                    <!-- Línea derecha -->
                    <BoxView Grid.Column="2"
                             HeightRequest="1"
                             BackgroundColor="{StaticResource TextSecondaryColorLight}"
                             VerticalOptions="Center" />
                </Grid>


                <!-- Sign In with Google -->
                <Button Grid.Row="1"
                     Text="Iniciar sesión con Google"
                     Style="{DynamicResource ButtonBold-XL-light}"
                     CornerRadius="{StaticResource CornerRadiusRectangle}"
                     ImageSource="googlelogopngsmall.png"
                 />
                <!-- Sign In with Apple -->
                <Button Grid.Row="2"
                     Text="Iniciar sesión con Apple"
                     Style="{DynamicResource ButtonBold-XL-light}"
                     CornerRadius="{StaticResource CornerRadiusRectangle}"
                     ImageSource="maciconlogopngsmall.png"
                 />
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>