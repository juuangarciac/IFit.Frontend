<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IFit.Views.ErrorView"
             Title="ErrorView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource  BackgroundPrimaryDark}">
    <!-- Main Grid -->
    <Grid BackgroundColor="{StaticResource  BackgroundPrimaryDark}" 
          HorizontalOptions="Center"
          VerticalOptions="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
            <!-- Title -->
            <Grid Grid.Row="0"
                  Margin="15, 15, 15, 15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                HorizontalTextAlignment="Center"
                VerticalTextAlignment="Center">
                <Label.FormattedText Grid.Column="0">
                        <FormattedString>
                            <Span Text="Ups! " 
                       TextColor="{StaticResource TertiaryColor}"
                       FontFamily="Montserrat-Bold"
                       FontSize="32"/>
                        <Span Text="Parece que se nos ha escapado algo.."
                       TextColor="{StaticResource TextPrimaryColorLight}"
                       FontFamily="Montserrat-Bold"
                       FontSize="26" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Button Grid.Column="1" 
                         BackgroundColor="Transparent"
                         ImageSource="cancel.svg"
                         Clicked="onCancelClicked" />
            </Grid>

        <!-- Image -->
        <Grid Grid.Row="1" 
              Margin="15, 15, 15, 15"
              HorizontalOptions="Center" 
              VerticalOptions="Center">
            <Image Source="errorimg.png" 
                   Aspect="AspectFit" />
        </Grid>

        <!-- Error Message -->
        <Label Grid.Row="2"
               Margin="15, 15, 15, 15"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
                Text="Intentelo más tarde, y si el problema persiste pónganse en contacto con soporte"
                Style="{StaticResource ErrorMessageStyle}"
                VerticalOptions="Center" 
                HorizontalOptions="Center"/>
    </Grid>
</ContentPage>