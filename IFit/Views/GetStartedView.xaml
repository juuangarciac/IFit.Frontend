<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IFit.Views.GetStartedView"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             Title="GetStartedView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundSecondaryDark}">
    <ContentPage.BindingContext>
        <vm:GetStartedViewModel />
    </ContentPage.BindingContext>
    <!-- Main Grid -->
    <Grid BackgroundColor="{DynamicResource BackgroundSecondaryDark}">
        
        <!-- BackGround Image -->
        <Image Source="getstarted.jpg"
                     Aspect="AspectFill"
                     Opacity="0.6"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill" />
        
        <!-- Foreground Content -->
        <Grid Margin="15, 45, 15, 45"
              HorizontalOptions="Center"
              VerticalOptions="Fill"
              RowSpacing="15">
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Cancel button  -->
            <Grid Grid.Row="0" >

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" 
                         HorizontalOptions="Start"
                         VerticalOptions="Start"
                         BackgroundColor="Transparent"
                         ImageSource="cancel.svg"
                         Clicked="onCancelClicked" />
            </Grid>
            
            <!-- Title/Subtile -->
            <Grid Grid.Row="1"
                  RowSpacing="15">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title Shadow -->
                <Label Grid.Row="0"
                       HorizontalTextAlignment="Center"
                       TranslationX="2"
                       TranslationY="2"
                       Opacity="0.5">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Bienvenido al club, "
                                  TextColor="Black"
                                  FontFamily="Montserrat-Bold"
                                  FontSize="32" />
                            <Span Text="{StaticResource newline}" />
                            <Span Text="{Binding Name}"
                                  TextColor="Black"
                                  FontFamily="Montserrat-Bold"
                                  FontSize="32" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                
                <!-- Title -->
                <Label Grid.Row="0"
                       HorizontalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Bienvenido al club, " 
                                     TextColor="{StaticResource TextPrimaryColorLight}"
                                     FontFamily="Montserrat-Bold"
                                     FontSize="32" />
                            <Span Text="{StaticResource newline}" />
                            <Span Text="{Binding Name}"
                                     TextColor="{StaticResource TertiaryColor}"
                                     FontFamily="Montserrat-Bold"
                                     FontSize="32" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <!-- Subtitle Shadow -->
                <Label Grid.Row="1"
                       HorizontalTextAlignment="Center"
                       LineHeight="1.5"
                       TranslationX="2"
                       TranslationY="2"
                       Opacity="0.5">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Ya formas parte de IFit. "
                                 TextColor="Black"
                                 FontFamily="Montserrat-SemiBold"
                                 FontSize="22" />
                            <Span Text="&#10;" />
                            <Span Text="Miles de "
                                    TextColor="Black"
                                    FontFamily="Montserrat-SemiBold"
                                    FontSize="22" />
                            <Span Text="IFitters"
                                   TextColor="Black"
                                   FontFamily="Montserrat-SemiBold"
                                   FontSize="22" />
                            <Span Text=" entrenan cada día con una sola meta:"
                                   TextColor="Black"
                                   FontFamily="Montserrat-SemiBold"
                                   FontSize="22" />
                            <Span Text="&#10;&#10;" />
                            <Span Text="Ser mejores que ayer "
                                   TextColor="Black"
                                   FontFamily="Montserrat-Bold"
                                   FontSize="22" />
                            <Span Text="&#10;&#10;" />
                            <Span Text="¿Estás listo?"
                                  TextColor="Black"
                                  FontFamily="Montserrat-SemiBold"
                                  FontSize="22" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                
                <!-- Subtitle -->
                <Label Grid.Row="1"
                       HorizontalTextAlignment="Center"
                       LineHeight="1.5" >
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Ya formas parte de IFit. "
                                     TextColor="{StaticResource TextPrimaryColorLight}"
                                     FontFamily="Montserrat-SemiBold"
                                     FontSize="22" />
                            <Span Text="&#10;" />
                            <Span Text="Miles de "
                                    TextColor="{StaticResource TextPrimaryColorLight}"
                                    FontFamily="Montserrat-SemiBold"
                                    FontSize="22" />
                            <Span Text="IFitters"
                                   TextColor="{StaticResource TertiaryColor}"
                                   FontFamily="Montserrat-SemiBold"
                                   FontSize="22" />
                            <Span Text=" entrenan cada día con una sola meta:"
                                   TextColor="{StaticResource TextPrimaryColorLight}"
                                   FontFamily="Montserrat-SemiBold"
                                   FontSize="22" />
                            <Span Text="&#10;&#10;" />
                            <Span Text="Ser mejores que ayer "
                                   TextColor="{StaticResource TertiaryColor}"
                                   FontFamily="Montserrat-Bold"
                                   FontSize="22" />
                            <Span Text="&#10;&#10;" />
                            <Span Text="¿Estás listo?"
                                  TextColor="{StaticResource TextPrimaryColorLight}"
                                  FontFamily="Montserrat-SemiBold"
                                  FontSize="22" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>
            
            <!-- Spam CheckBox / Buton to Continue -->
            <Grid Grid.Row="2"
                  RowSpacing="15" >

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                
                <!-- Email Spam advice -->
                <Border Grid.Row="0"
                        Style="{StaticResource BorderBackgroundLightGray}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20, 20, 20, 20">
                    
                    <Grid Padding="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  VerticalOptions="Center"
                                  HorizontalOptions="Center"
                                  Color="White"/>

                        <Label Grid.Column="1"
                               Text="Recibe en tu email anuncios exclusivos, ofertas especiales, publicaciones inspiradoras y tutoriales para exprimir al máximo tu app móvil"
                               HorizontalOptions="Start"
                               VerticalOptions="Center"
                               HorizontalTextAlignment="Start"
                               LineBreakMode="WordWrap"
                               TextColor="{StaticResource TextPrimaryColorLight}"
                               FontFamily="Montserrat-Regular"
                               FontSize="14"
                               MaxLines="4" />
                    </Grid>
                  
                </Border>

                <!-- Buton to continue -->
                <Button Grid.Row="1"
                        Text="Empieza ahora"
                        Style="{StaticResource ButtonBold-XL-yellow}"
                        CornerRadius="{StaticResource CornerRadiusRectangle}"
                        Clicked="onContinueClicked"/>
            </Grid>
          
        </Grid>
    </Grid>
</ContentPage>