<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IFit.Views.ExperienceLevelSelectionView"
             xmlns:components="clr-namespace:IFit.Views.Components"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:models="clr-namespace:IFit.Models.Dtos.ExperienceLevel"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:ExperienceLevelViewModel/>
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,Auto,*" Padding="20,50,20,20" RowSpacing="16">

        <!-- Row 0: Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

            <Button Grid.Column="0"
                    BackgroundColor="Transparent"
                    ImageSource="arrow.png"
                    VerticalOptions="Center"
                    Clicked="onCancelClicked" />

            <BoxView Grid.Column="1"
                     BackgroundColor="{StaticResource TextSecondaryColorLight}"
                     HeightRequest="1"
                     VerticalOptions="Center"
                     Opacity="0.4" />

            <Button Grid.Column="2"
                    BackgroundColor="Transparent"
                    ImageSource="cancel.svg"
                    VerticalOptions="Center"
                    Clicked="onCloseClicked" />
        </Grid>

        <!-- Row 1: Title -->
        <Label Grid.Row="1"
               Text="¿Qué experiencia tienes en el mundo fitness?"
               Style="{StaticResource label-h1-white}" />

        <!-- Row 2: Experience Levels -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding ExperienceLevels}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedExperienceLevel, Mode=TwoWay}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ExperienceLevelDto">
                    <Border StrokeThickness="0"
                            Margin="0,0,0,8">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="{StaticResource BackgroundSecondaryDark}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="{StaticResource BackgroundPrimaryDark}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid Padding="12,10" RowSpacing="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0"
                                   Text="{Binding Name}"
                                   Style="{StaticResource label-h2-white}" />
                            <Label Grid.Row="1"
                                   Text="{Binding Description}"
                                   Style="{StaticResource label-p-white}"
                                   Opacity="0.8" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading Overlay -->
        <components:LoadingOverlay Grid.RowSpan="3"
                                   IsLoading="{Binding IsLoading}"
                                   Message="{Binding StatusMessage}" />
    </Grid>
</ContentPage>
