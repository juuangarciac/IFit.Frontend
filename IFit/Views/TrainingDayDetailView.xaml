<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IFit.Views.TrainingDayDetailView"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:views="clr-namespace:IFit.Views.Templates"
             xmlns:dto="clr-namespace:IFit.Models.Dtos.AI"
             xmlns:components="clr-namespace:IFit.Views.Components"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundPrimaryDark}">
    <ContentPage.BindingContext>
        <vm:TrainingDayDetailViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              VerticalOptions="Start"
              Background="{Binding Background}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Navbar -->
            <Grid Grid.Row="0" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        BackgroundColor="Transparent"
                        ImageSource="arrow.png"
                        Command="{Binding GoBackCommand}" />
                <Image Grid.Column="0"
                       Grid.ColumnSpan="2"
                       Source="ifit_logo_white.png"
                       HeightRequest="20"
                       WidthRequest="120"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Grid>

            <!-- Título + metadatos -->
            <VerticalStackLayout Grid.Row="1"
                                 Margin="15,0,15,20"
                                 Spacing="4">
                <Label Text="{Binding DateNowFormatted}"
                       Style="{DynamicResource label-p-white}"
                       Opacity="0.7" />
                <Label Text="{Binding TrainingDay.DayName}"
                       Style="{DynamicResource label-Title-white}" />
                <HorizontalStackLayout Spacing="16" Margin="0,4,0,0">
                    <HorizontalStackLayout Spacing="6">
                        <Image Source="clock64.png"
                               HeightRequest="16"
                               WidthRequest="16"
                               VerticalOptions="Center" />
                        <Label Text="{Binding EstimatedDuration}"
                               Style="{StaticResource label-p-white}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="·"
                               Style="{StaticResource label-p-white}"
                               Opacity="0.5"
                               VerticalOptions="Center" />
                        <Label Text="{Binding ExerciseCount, StringFormat='{0} ejercicios'}"
                               Style="{StaticResource label-p-white}"
                               Opacity="0.8"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <!-- Body scrollable -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Margin="15,12,15,0">

                <!-- Separator -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{StaticResource TextSecondaryColorLight}"
                         Margin="0,0,0,12" />

                <!-- Descripción -->
                <Label Text="Descripción"
                       Style="{StaticResource label-h2-white}"
                       Margin="0,0,0,8" />

                <Border StrokeThickness="0"
                        Margin="0,0,0,16"
                        BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="{Binding TrainingDay.Description}"
                           Style="{StaticResource label-p-white}"
                           Padding="12,10" />
                </Border>

                <!-- Ejercicios -->
                <Label Text="Ejercicios"
                       Style="{StaticResource label-h2-white}"
                       Margin="0,0,0,8" />

                <CollectionView ItemsSource="{Binding TrainingDay.Exercises}"
                                SelectionMode="Single"
                                SelectedItem="{Binding SelectedExercise}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:ExerciseDto">
                            <Border StrokeThickness="0"
                                    Margin="0,0,0,8">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource BackgroundSecondaryDark}"/>
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource BackgroundPrimaryDark}"/>
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Grid Padding="12,10" RowSpacing="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0"
                                               Text="{Binding ExerciseName}"
                                               Style="{StaticResource label-h2-white}" />
                                        <HorizontalStackLayout Grid.Column="1"
                                                               Spacing="6"
                                                               HorizontalOptions="End"
                                                               VerticalOptions="Center">

                                            <!-- Catálogo -->
                                            <Border StrokeThickness="1.5"
                                                    Stroke="{StaticResource TertiaryColor}"
                                                    BackgroundColor="Transparent"
                                                    WidthRequest="30"
                                                    HeightRequest="30">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="15"/>
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenInCatalogCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Image Source="arrow_icon_white.png"
                                                       WidthRequest="12"
                                                       HeightRequest="12"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       InputTransparent="True" />
                                            </Border>

                                            <!-- IA -->
                                            <Border StrokeThickness="0"
                                                    BackgroundColor="{StaticResource TertiaryColor}"
                                                    WidthRequest="30"
                                                    HeightRequest="30">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="15"/>
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ExplainExerciseCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="IA"
                                                       TextColor="{StaticResource BackgroundPrimaryDark}"
                                                       FontFamily="Montserrat-Bold"
                                                       FontSize="11"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>

                                        </HorizontalStackLayout>
                                    </Grid>

                                    <Label Grid.Row="1" Style="{StaticResource label-p-white}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Sets}"
                                                      FontFamily="Montserrat-Bold"
                                                      TextColor="{StaticResource TertiaryColor}"/>
                                                <Span Text=" series  ·  "/>
                                                <Span Text="{Binding Reps}"
                                                      FontFamily="Montserrat-Bold"
                                                      TextColor="{StaticResource TertiaryColor}"/>
                                                <Span Text=" reps  ·  "/>
                                                <Span Text="{Binding RestSeconds}"
                                                      FontFamily="Montserrat-Bold"
                                                      TextColor="{StaticResource TertiaryColor}"/>
                                                <Span Text=" seg"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Botón fijo / mensaje contextual -->
        <Grid Grid.Row="2" Margin="15">
            <Button Text="Finalizar sesión"
                    Style="{StaticResource ButtonBold-XL-yellow}"
                    CornerRadius="{StaticResource CornerRadiusRectangle}"
                    Command="{Binding EndSessionCommand}"
                    IsEnabled="{Binding CanEndSession}"
                    IsVisible="{Binding CanEndSession}" />

            <Label Text="{Binding SessionStatusMessage}"
                   Style="{StaticResource label-p-white}"
                   HorizontalTextAlignment="Center"
                   Opacity="0.6"
                   IsVisible="{Binding CanEndSession,
                       Converter={StaticResource InvertedBoolConverter}}" />
        </Grid>

        <!-- Loading overlay -->
        <components:LoadingOverlay
            Grid.RowSpan="3"
            IsLoading="{Binding IsLoading}"
            Message="{Binding StatusMessage}" />

        <!-- Modal: explicación de ejercicio -->
        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsExplanationModalVisible}">

            <!-- Fondo semitransparente — tap para cerrar -->
            <BoxView BackgroundColor="#BB000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseExplanationCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Card centrada -->
            <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    HorizontalOptions="Fill"
                    Margin="20,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12" Padding="16">

                    <!-- Header: nombre + cerrar -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0"
                               Text="{Binding ExplanationExerciseName}"
                               Style="{StaticResource label-h2-white}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="✕"
                               TextColor="{StaticResource TextPrimaryColorLight}"
                               FontSize="18"
                               MinimumWidthRequest="36"
                               MinimumHeightRequest="36"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CloseExplanationCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource TextSecondaryColorLight}"
                             Opacity="0.25"/>

                    <!-- Spinner mientras carga -->
                    <ActivityIndicator IsRunning="{Binding IsExplanationLoading}"
                                       IsVisible="{Binding IsExplanationLoading}"
                                       Color="{StaticResource TertiaryColor}"
                                       HorizontalOptions="Center"/>

                    <!-- Texto de la explicación -->
                    <ScrollView MaximumHeightRequest="320"
                                IsVisible="{Binding IsExplanationLoading,
                                    Converter={StaticResource InvertedBoolConverter}}">
                        <Label Text="{Binding ExplanationText}"
                               Style="{StaticResource label-p-white}"
                               LineBreakMode="WordWrap"/>
                    </ScrollView>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Modal: ejercicio no disponible en catálogo -->
        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsCatalogNotFoundModalVisible}">

            <!-- Fondo semitransparente -->
            <BoxView BackgroundColor="#BB000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseCatalogNotFoundCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Card centrada -->
            <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    HorizontalOptions="Fill"
                    Margin="20,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12" Padding="16">

                    <!-- Header: nombre + cerrar -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0"
                               Text="{Binding CatalogNotFoundExerciseName}"
                               Style="{StaticResource label-h2-white}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="✕"
                               TextColor="{StaticResource TextPrimaryColorLight}"
                               FontSize="18"
                               MinimumWidthRequest="36"
                               MinimumHeightRequest="36"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CloseCatalogNotFoundCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource TextSecondaryColorLight}"
                             Opacity="0.25"/>

                    <!-- Icono de estado -->
                    <Border StrokeThickness="0"
                            BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                            WidthRequest="48"
                            HeightRequest="48"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24"/>
                        </Border.StrokeShape>
                        <Label Text="↗"
                               TextColor="{StaticResource TertiaryColor}"
                               FontSize="22"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <!-- Mensaje -->
                    <Label Text="Este ejercicio todavía no está en nuestro catálogo."
                           Style="{StaticResource label-h3-white}"
                           HorizontalTextAlignment="Center"
                           Opacity="0.9"/>

                    <Label Text="Seguimos ampliándolo continuamente — no tardará en estar disponible."
                           Style="{StaticResource label-p-white}"
                           HorizontalTextAlignment="Center"
                           Opacity="0.65"
                           LineBreakMode="WordWrap"/>

                    <!-- CTA: explorar catálogo de todas formas -->
                    <Button Text="Explorar catálogo"
                            Style="{StaticResource ButtonBold-XL-yellow}"
                            CornerRadius="{StaticResource CornerRadiusRectangle}"
                            Command="{Binding OpenCatalogAnywayCommand}"
                            Margin="0,4,0,0"/>

                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
