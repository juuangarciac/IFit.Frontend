<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:dtos="clr-namespace:IFit.Models.Dtos.Questionnaire"
             xmlns:converters="clr-namespace:IFit.Converters"
             xmlns:components="clr-namespace:IFit.Views.Components"
             x:Class="IFit.Views.QuestionnaireSummaryView"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:AnswerTextConverter x:Key="AnswerTextConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <vm:QuetionnaireSummaryViewModel />
    </ContentPage.BindingContext>

    <Grid>

        <!-- Loading Overlay -->
        <components:LoadingOverlay IsLoading="{Binding IsLoading}"
                                   Message="{Binding StatusMessage}"
                                   ZIndex="999"/>

        <Grid RowDefinitions="Auto,Auto,*,Auto"
              Padding="20,50,20,20"
              RowSpacing="16"
              ZIndex="1">

            <!-- Row 0: Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                <Button Grid.Column="0"
                        BackgroundColor="Transparent"
                        ImageSource="arrow.png"
                        VerticalOptions="Center"
                        Clicked="onCancelClicked" />

                <BoxView Grid.Column="1"
                         BackgroundColor="{StaticResource TextSecondaryColorLight}"
                         HeightRequest="1"
                         VerticalOptions="Center"
                         Opacity="0.4" />

                <Button Grid.Column="2"
                        BackgroundColor="Transparent"
                        ImageSource="cancel.svg"
                        VerticalOptions="Center"
                        Clicked="onCloseClicked" />
            </Grid>

            <!-- Row 1: Title + descripción (solo cuando se puede generar) -->
            <VerticalStackLayout Grid.Row="1"
                                 Spacing="8"
                                 IsVisible="{Binding ShowStartButton}">

                <Label Text="Esto es lo que sabemos sobre tí"
                       Style="{StaticResource label-h1-white}" />

                <Label>
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Esta información se pasará a "
                                  FontFamily="Montserrat-Medium"
                                  TextColor="{StaticResource TextPrimaryColorLight}"
                                  FontSize="14" />
                            <Span Text="{Binding CoachName}"
                                  FontFamily="Montserrat-Medium"
                                  TextColor="{StaticResource TertiaryColor}"
                                  FontSize="14" />
                            <Span Text=" , para generar tú rutina."
                                  FontFamily="Montserrat-Medium"
                                  TextColor="{StaticResource TextPrimaryColorLight}"
                                  FontSize="14" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </VerticalStackLayout>

            <!-- Row 2: Resumen del cuestionario -->
            <ScrollView Grid.Row="2">
                <VerticalStackLayout Spacing="0">

                    <Label Text="{Binding QuestionnaireName}"
                           Style="{StaticResource label-h2-white}"
                           Margin="0,0,0,12" />

                    <CollectionView ItemsSource="{Binding QuestionnaireSummary.Answers}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dtos:AnswerDTO">
                                <Border StrokeThickness="0"
                                        Margin="0,0,0,8"
                                        BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Grid Padding="12,10" RowSpacing="5">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Label Grid.Row="0"
                                               Text="{Binding QuestionText}"
                                               Style="{StaticResource label-h3-white}" />
                                        <Label Grid.Row="1"
                                               Text="{Binding ., Converter={StaticResource AnswerTextConverter}}"
                                               Style="{StaticResource label-p-white}"
                                               Opacity="0.8" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Row 3: CTA -->
            <Button Grid.Row="3"
                    Text="Generar rutina"
                    Style="{StaticResource ButtonBold-XL-yellow}"
                    CornerRadius="{StaticResource CornerRadiusRectangle}"
                    Command="{Binding StartGenerationCommand}"
                    HorizontalOptions="Fill" />

        </Grid>
    </Grid>
</ContentPage>
