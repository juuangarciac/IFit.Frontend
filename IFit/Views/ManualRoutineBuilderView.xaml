<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:dtos="clr-namespace:IFit.Models.Dtos.Exercise"
             xmlns:components="clr-namespace:IFit.Views.Components"
             x:Class="IFit.Views.ManualRoutineBuilderView"
             x:Name="ManualRoutineBuilderPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource BackgroundPrimaryDark}">

    <ContentPage.BindingContext>
        <vm:ManualRoutineBuilderViewModel />
    </ContentPage.BindingContext>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Loading overlay -->
        <components:LoadingOverlay Grid.RowSpan="2"
                                   IsLoading="{Binding IsLoading}"
                                   Message="{Binding StatusMessage}"
                                   ZIndex="999" />

        <!-- ── Row 0: Header ─────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              Padding="15,50,15,10"
              ColumnSpacing="12"
              ColumnDefinitions="Auto,*">

            <ImageButton Grid.Column="0"
                         Source="arrow_icon_white.png"
                         HeightRequest="20"
                         WidthRequest="20"
                         VerticalOptions="Center"
                         Rotation="180"
                         Command="{Binding GoBackCommand}" />

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="1"
                                 VerticalOptions="Center">
                <Label Text="Crear rutina"
                       Style="{DynamicResource label-h1-white}"
                       FontSize="22" />
                <Label Text="{Binding Description}"
                       Style="{DynamicResource label-h1-yellow}"
                       FontSize="14"
                       IsVisible="{Binding IsStep2}"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>
        </Grid>

        <!-- ── Row 1: Contenido principal ────────────────────────────── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Padding="15,8,15,30">

                <!-- ══ PASO 1: Configuración inicial ══════════════════ -->
                <VerticalStackLayout Spacing="16"
                                     IsVisible="{Binding IsStep1}">

                    <!-- Descripción -->
                    <Border BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                            StrokeThickness="2"
                            Stroke="{DynamicResource BackgroundPrimaryLight}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="15" Spacing="8">
                            <Label Text="Nombre de la rutina"
                                   Style="{DynamicResource label-h2-white}" />
                            <BoxView HeightRequest="1"
                                     Color="{DynamicResource QuaternaryColor}"
                                     Opacity="0.3"
                                     HorizontalOptions="Fill" />
                            <Border BackgroundColor="{DynamicResource BackgroundPrimaryLight}"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry Text="{Binding Description, Mode=TwoWay}"
                                       Placeholder="Ej: Fuerza 3 días"
                                       PlaceholderColor="{DynamicResource BackgroundPrimaryDark}"
                                       TextColor="{DynamicResource BackgroundPrimaryDark}"
                                       BackgroundColor="Transparent"
                                       Margin="8,0" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Número de días -->
                    <Border BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                            StrokeThickness="2"
                            Stroke="{DynamicResource BackgroundPrimaryLight}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="15" Spacing="8">
                            <Label Text="Días de entrenamiento"
                                   Style="{DynamicResource label-h2-white}" />
                            <BoxView HeightRequest="1"
                                     Color="{DynamicResource QuaternaryColor}"
                                     Opacity="0.3"
                                     HorizontalOptions="Fill" />
                            <Label Text="¿Cuántos días a la semana entrenas?"
                                   Style="{DynamicResource label-p-white}"
                                   Opacity="0.65"
                                   FontSize="13" />

                            <!-- Stepper: - N + -->
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12"
                                  HorizontalOptions="Center"
                                  Margin="0,4,0,0">

                                <Button Grid.Column="0"
                                        Text="−"
                                        Command="{Binding DecreaseDaysCommand}"
                                        Style="{DynamicResource ButtonBold-XL-dark-yellow}"
                                        FontSize="22"
                                        WidthRequest="52"
                                        HeightRequest="52"
                                        CornerRadius="26"
                                        Padding="0" />

                                <Label Grid.Column="1"
                                       Text="{Binding TrainingDaysText}"
                                       Style="{DynamicResource label-h1-yellow}"
                                       FontSize="36"
                                       HorizontalTextAlignment="Center"
                                       VerticalOptions="Center" />

                                <Button Grid.Column="2"
                                        Text="+"
                                        Command="{Binding IncreaseDaysCommand}"
                                        Style="{DynamicResource ButtonBold-XL-yellow}"
                                        FontSize="22"
                                        WidthRequest="52"
                                        HeightRequest="52"
                                        CornerRadius="26"
                                        Padding="0" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Botón continuar -->
                    <Button Text="Continuar →"
                            Command="{Binding ContinueCommand}"
                            Style="{DynamicResource ButtonBold-XL-yellow}"
                            CornerRadius="{DynamicResource CornerRadiusRectangle}"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>

                <!-- ══ PASO 2: Editor de días ══════════════════════════ -->
                <VerticalStackLayout Spacing="14"
                                     IsVisible="{Binding IsStep2}">

                    <!-- Navegador de días -->
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8">

                        <Button Grid.Column="0"
                                Text="◀"
                                Command="{Binding GoToPreviousDayCommand}"
                                IsVisible="{Binding HasMultipleDays}"
                                BackgroundColor="Transparent"
                                TextColor="{DynamicResource TertiaryColor}"
                                FontSize="22"
                                WidthRequest="40"
                                Padding="0" />

                        <Label Grid.Column="1"
                               Text="{Binding DayIndicatorText}"
                               Style="{DynamicResource label-h2-white}"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center" />

                        <Button Grid.Column="2"
                                Text="▶"
                                Command="{Binding GoToNextDayCommand}"
                                IsVisible="{Binding HasMultipleDays}"
                                BackgroundColor="Transparent"
                                TextColor="{DynamicResource TertiaryColor}"
                                FontSize="22"
                                WidthRequest="40"
                                Padding="0" />
                    </Grid>

                    <!-- Nombre del día -->
                    <Border BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                            StrokeThickness="2"
                            Stroke="{DynamicResource BackgroundPrimaryLight}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="15" Spacing="8">
                            <Label Text="Nombre del día"
                                   Style="{DynamicResource label-p-white}"
                                   FontSize="12"
                                   Opacity="0.6" />
                            <Border BackgroundColor="{DynamicResource BackgroundPrimaryLight}"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry Text="{Binding CurrentDay.DayName, Mode=TwoWay}"
                                       Placeholder="Ej: Pecho y tríceps"
                                       PlaceholderColor="{DynamicResource BackgroundPrimaryDark}"
                                       TextColor="{DynamicResource BackgroundPrimaryDark}"
                                       BackgroundColor="Transparent"
                                       Margin="8,0" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Buscador de ejercicios ─────────────────────── -->
                    <Border BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                            StrokeThickness="2"
                            Stroke="{DynamicResource BackgroundPrimaryLight}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="15" Spacing="10">

                            <Label Text="Añadir ejercicios"
                                   Style="{DynamicResource label-h2-white}" />

                            <BoxView HeightRequest="1"
                                     Color="{DynamicResource QuaternaryColor}"
                                     Opacity="0.3"
                                     HorizontalOptions="Fill" />

                            <!-- Barra de búsqueda -->
                            <Border BackgroundColor="{DynamicResource BackgroundPrimaryLight}"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,Auto" Padding="10,0">
                                    <Entry Grid.Column="0"
                                           Text="{Binding SearchText, Mode=TwoWay}"
                                           Placeholder="Buscar por músculo, ej: pecho"
                                           PlaceholderColor="{DynamicResource BackgroundPrimaryDark}"
                                           TextColor="{DynamicResource BackgroundPrimaryDark}"
                                           BackgroundColor="Transparent"
                                           ReturnType="Search"
                                           ReturnCommand="{Binding SearchCommand}" />
                                    <Button Grid.Column="1"
                                            Text="Buscar"
                                            Command="{Binding SearchCommand}"
                                            Style="{DynamicResource ButtonBold-XL-yellow}"
                                            FontSize="12"
                                            Padding="12,0"
                                            VerticalOptions="Center"
                                            CornerRadius="8" />
                                </Grid>
                            </Border>

                            <!-- Resultados de búsqueda -->
                            <VerticalStackLayout IsVisible="{Binding IsSearching}"
                                                 Spacing="6">

                                <!-- Botón limpiar búsqueda -->
                                <Button Text="✕ Cerrar búsqueda"
                                        Command="{Binding ClearSearchCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{DynamicResource TextSecondaryColorLight}"
                                        FontSize="12"
                                        HorizontalOptions="End"
                                        Padding="0" />

                                <!-- Lista de resultados -->
                                <VerticalStackLayout Spacing="6"
                                                     BindableLayout.ItemsSource="{Binding SearchResults}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="dtos:ExerciseSummaryDto">
                                            <Border BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                                                    StrokeThickness="1"
                                                    Stroke="{DynamicResource BackgroundPrimaryLight}"
                                                    Padding="12,10">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10" />
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={x:Reference ManualRoutineBuilderPage}, Path=BindingContext.AddExerciseCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                                        <Label Text="{Binding Name}"
                                                               Style="{DynamicResource label-h2-white}"
                                                               FontSize="14"
                                                               LineBreakMode="WordWrap" />
                                                        <Label FontSize="11"
                                                               Opacity="0.65">
                                                            <Label.FormattedText>
                                                                <FormattedString>
                                                                    <Span Text="{Binding Category}"
                                                                          TextColor="{DynamicResource TextSecondaryColorLight}"
                                                                          FontFamily="Montserrat-Medium" />
                                                                    <Span Text=" · "
                                                                          TextColor="{DynamicResource TextSecondaryColorLight}" />
                                                                    <Span Text="{Binding Level}"
                                                                          TextColor="{DynamicResource TertiaryColor}"
                                                                          FontFamily="Montserrat-Medium" />
                                                                </FormattedString>
                                                            </Label.FormattedText>
                                                        </Label>
                                                    </VerticalStackLayout>
                                                    <Label Grid.Column="1"
                                                           Text="+"
                                                           TextColor="{DynamicResource TertiaryColor}"
                                                           FontSize="24"
                                                           FontAttributes="Bold"
                                                           VerticalOptions="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <!-- Sin resultados -->
                                <Label Text="{Binding StatusMessage}"
                                       IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                       Style="{DynamicResource label-p-white}"
                                       HorizontalTextAlignment="Center"
                                       Opacity="0.6" />
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Ejercicios del día actual ──────────────────── -->
                    <Border BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                            StrokeThickness="2"
                            Stroke="{DynamicResource BackgroundPrimaryLight}"
                            IsVisible="{Binding ShowExerciseList}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="15" Spacing="10">

                            <Label Text="Ejercicios del día"
                                   Style="{DynamicResource label-h2-white}" />

                            <BoxView HeightRequest="1"
                                     Color="{DynamicResource QuaternaryColor}"
                                     Opacity="0.3"
                                     HorizontalOptions="Fill" />

                            <!-- Lista de ejercicios añadidos -->
                            <VerticalStackLayout Spacing="10"
                                                 BindableLayout.ItemsSource="{Binding CurrentDay.Exercises}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ManualExerciseEntry">
                                        <Border BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                                                StrokeThickness="1"
                                                Stroke="{DynamicResource BackgroundPrimaryLight}"
                                                Padding="12,10">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="10" />
                                            </Border.StrokeShape>
                                            <VerticalStackLayout Spacing="8">

                                                <!-- Nombre + botón eliminar -->
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <Label Grid.Column="0"
                                                           Text="{Binding ExerciseName}"
                                                           Style="{DynamicResource label-h2-white}"
                                                           FontSize="14"
                                                           LineBreakMode="WordWrap"
                                                           VerticalOptions="Center" />
                                                    <Button Grid.Column="1"
                                                            Text="✕"
                                                            Command="{Binding Source={x:Reference ManualRoutineBuilderPage}, Path=BindingContext.RemoveExerciseCommand}"
                                                            CommandParameter="{Binding .}"
                                                            BackgroundColor="Transparent"
                                                            TextColor="{DynamicResource TextSecondaryColorLight}"
                                                            FontSize="16"
                                                            Padding="0"
                                                            WidthRequest="32"
                                                            HeightRequest="32" />
                                                </Grid>

                                                <!-- Series · Reps · Descanso -->
                                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

                                                    <!-- Series -->
                                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                                        <Label Text="Series"
                                                               Style="{DynamicResource label-p-white}"
                                                               FontSize="11"
                                                               Opacity="0.6" />
                                                        <Border BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                                                                StrokeThickness="1"
                                                                Stroke="{DynamicResource BackgroundPrimaryLight}">
                                                            <Border.StrokeShape>
                                                                <RoundRectangle CornerRadius="6" />
                                                            </Border.StrokeShape>
                                                            <Entry Text="{Binding Sets, Mode=TwoWay}"
                                                                   TextColor="White"
                                                                   BackgroundColor="Transparent"
                                                                   Keyboard="Numeric"
                                                                   HorizontalTextAlignment="Center"
                                                                   FontSize="14"
                                                                   Margin="4,0" />
                                                        </Border>
                                                    </VerticalStackLayout>

                                                    <!-- Reps -->
                                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                                        <Label Text="Reps"
                                                               Style="{DynamicResource label-p-white}"
                                                               FontSize="11"
                                                               Opacity="0.6" />
                                                        <Border BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                                                                StrokeThickness="1"
                                                                Stroke="{DynamicResource BackgroundPrimaryLight}">
                                                            <Border.StrokeShape>
                                                                <RoundRectangle CornerRadius="6" />
                                                            </Border.StrokeShape>
                                                            <Entry Text="{Binding Reps, Mode=TwoWay}"
                                                                   TextColor="White"
                                                                   BackgroundColor="Transparent"
                                                                   HorizontalTextAlignment="Center"
                                                                   FontSize="14"
                                                                   Margin="4,0" />
                                                        </Border>
                                                    </VerticalStackLayout>

                                                    <!-- Descanso -->
                                                    <VerticalStackLayout Grid.Column="2" Spacing="3">
                                                        <Label Text="Descanso (s)"
                                                               Style="{DynamicResource label-p-white}"
                                                               FontSize="11"
                                                               Opacity="0.6" />
                                                        <Border BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                                                                StrokeThickness="1"
                                                                Stroke="{DynamicResource BackgroundPrimaryLight}">
                                                            <Border.StrokeShape>
                                                                <RoundRectangle CornerRadius="6" />
                                                            </Border.StrokeShape>
                                                            <Entry Text="{Binding RestSeconds, Mode=TwoWay}"
                                                                   TextColor="White"
                                                                   BackgroundColor="Transparent"
                                                                   Keyboard="Numeric"
                                                                   HorizontalTextAlignment="Center"
                                                                   FontSize="14"
                                                                   Margin="4,0" />
                                                        </Border>
                                                    </VerticalStackLayout>

                                                </Grid>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <!-- Instrucción estática -->
                            <Label Text="Busca ejercicios arriba y pulsa + para añadirlos al día."
                                   Style="{DynamicResource label-p-white}"
                                   HorizontalTextAlignment="Center"
                                   Opacity="0.45"
                                   FontSize="12"
                                   Margin="0,4" />

                        </VerticalStackLayout>
                    </Border>

                    <!-- Botón guardar -->
                    <Button Text="Guardar rutina"
                            Command="{Binding SaveRoutineCommand}"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                            Style="{DynamicResource ButtonBold-XL-yellow}"
                            CornerRadius="{DynamicResource CornerRadiusRectangle}"
                            HorizontalOptions="Fill"
                            IsVisible="{Binding ShowExerciseList}" />

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
