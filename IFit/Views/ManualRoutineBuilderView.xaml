<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:dtos="clr-namespace:IFit.Models.Dtos.Exercise"
             xmlns:components="clr-namespace:IFit.Views.Components"
             x:Class="IFit.Views.ManualRoutineBuilderView"
             x:Name="ManualRoutineBuilderPage"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:ManualRoutineBuilderViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- Loading overlay -->
        <components:LoadingOverlay Grid.RowSpan="2"
                                   IsLoading="{Binding IsLoading}"
                                   Message="{Binding StatusMessage}"
                                   ZIndex="999" />

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              Padding="15,50,15,12"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="12">

            <ImageButton Grid.Column="0"
                         Source="arrow_icon_white.png"
                         HeightRequest="20"
                         WidthRequest="20"
                         VerticalOptions="Center"
                         Rotation="180"
                         Command="{Binding GoBackCommand}" />

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <Label Text="{Binding StepIndicatorText}"
                       Style="{StaticResource label-p-white}"
                       FontSize="11"
                       CharacterSpacing="2"
                       Opacity="0.6" />
                <Label Text="Crear rutina"
                       Style="{StaticResource label-h1-white}" />
                <Label Text="{Binding Description}"
                       Style="{StaticResource label-p-white}"
                       Opacity="0.7"
                       IsVisible="{Binding IsStep2}"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>
        </Grid>

        <!-- ── Contenido ──────────────────────────────────────────────── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" Padding="15,8,15,30">

                <!-- ══ PASO 1: Configuración inicial ══════════════════════ -->
                <VerticalStackLayout Spacing="12" IsVisible="{Binding IsStep1}">

                    <!-- Card: Nombre de la rutina -->
                    <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="15" Spacing="10">
                            <Label Text="Nombre de la rutina"
                                   Style="{StaticResource label-h2-white}" />
                            <BoxView HeightRequest="1"
                                     BackgroundColor="{StaticResource TextSecondaryColorLight}"
                                     Opacity="0.15"
                                     HorizontalOptions="Fill" />
                            <Border Style="{StaticResource BorderRectangleWhite}">
                                <Entry Text="{Binding Description, Mode=TwoWay}"
                                       Placeholder="Ej: Fuerza 3 días"
                                       PlaceholderColor="{StaticResource BackgroundSecondaryDark}"
                                       TextColor="{StaticResource BackgroundPrimaryDark}"
                                       BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Card: Días de entrenamiento -->
                    <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="15" Spacing="10">
                            <Label Text="Días de entrenamiento"
                                   Style="{StaticResource label-h2-white}" />
                            <BoxView HeightRequest="1"
                                     BackgroundColor="{StaticResource TextSecondaryColorLight}"
                                     Opacity="0.15"
                                     HorizontalOptions="Fill" />
                            <Label Text="¿Cuántos días a la semana entrenas?"
                                   Style="{StaticResource label-p-white}"
                                   Opacity="0.65" />

                            <!-- Stepper: − N + -->
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="16"
                                  HorizontalOptions="Center"
                                  Margin="0,4">
                                <Button Grid.Column="0"
                                        Text="−"
                                        Command="{Binding DecreaseDaysCommand}"
                                        Style="{StaticResource ButtonBold-XL-dark-yellow}"
                                        FontSize="20"
                                        WidthRequest="52"
                                        HeightRequest="52"
                                        CornerRadius="26"
                                        Padding="0" />
                                <Label Grid.Column="1"
                                       Text="{Binding TrainingDaysText}"
                                       Style="{StaticResource label-Title-white}"
                                       HorizontalTextAlignment="Center"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="2"
                                        Text="+"
                                        Command="{Binding IncreaseDaysCommand}"
                                        Style="{StaticResource ButtonBold-XL-yellow}"
                                        FontSize="20"
                                        WidthRequest="52"
                                        HeightRequest="52"
                                        CornerRadius="26"
                                        Padding="0" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- CTA: Continuar al paso 2 -->
                    <Button Text="Continuar →"
                            Command="{Binding ContinueCommand}"
                            Style="{StaticResource ButtonBold-XL-yellow}"
                            CornerRadius="{StaticResource CornerRadiusRectangle}"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>

                <!-- ══ PASO 2: Editor de días ════════════════════════════ -->
                <VerticalStackLayout Spacing="12" IsVisible="{Binding IsStep2}">

                    <!-- Navegador de días -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">

                        <Button Grid.Column="0"
                                Text="◀"
                                Command="{Binding GoToPreviousDayCommand}"
                                IsVisible="{Binding HasMultipleDays}"
                                BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                                TextColor="{StaticResource TertiaryColor}"
                                FontFamily="Montserrat-Bold"
                                FontSize="16"
                                WidthRequest="44"
                                HeightRequest="44"
                                CornerRadius="8"
                                Padding="0" />

                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="{Binding DayIndicatorText}"
                                   Style="{StaticResource label-h2-white}"
                                   HorizontalTextAlignment="Center"
                                   Padding="12,10" />
                        </Border>

                        <Button Grid.Column="2"
                                Text="▶"
                                Command="{Binding GoToNextDayCommand}"
                                IsVisible="{Binding HasMultipleDays}"
                                BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                                TextColor="{StaticResource TertiaryColor}"
                                FontFamily="Montserrat-Bold"
                                FontSize="16"
                                WidthRequest="44"
                                HeightRequest="44"
                                CornerRadius="8"
                                Padding="0" />
                    </Grid>

                    <!-- Card: Nombre del día -->
                    <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="15" Spacing="10">
                            <Label Text="Nombre del día"
                                   Style="{StaticResource label-p-white}"
                                   Opacity="0.6" />
                            <Border Style="{StaticResource BorderRectangleWhite}">
                                <Entry Text="{Binding CurrentDay.DayName, Mode=TwoWay}"
                                       Placeholder="Ej: Pecho y tríceps"
                                       PlaceholderColor="{StaticResource BackgroundSecondaryDark}"
                                       TextColor="{StaticResource BackgroundPrimaryDark}"
                                       BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Card: Añadir ejercicios (buscador) -->
                    <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="15" Spacing="10">

                            <Label Text="Añadir ejercicios"
                                   Style="{StaticResource label-h2-white}" />
                            <BoxView HeightRequest="1"
                                     BackgroundColor="{StaticResource TextSecondaryColorLight}"
                                     Opacity="0.15"
                                     HorizontalOptions="Fill" />

                            <!-- Barra de búsqueda -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Border Grid.Column="0"
                                        Style="{StaticResource BorderRectangleWhite}">
                                    <Entry Text="{Binding SearchText, Mode=TwoWay}"
                                           Placeholder="Buscar por músculo, ej: pecho"
                                           PlaceholderColor="{StaticResource BackgroundSecondaryDark}"
                                           TextColor="{StaticResource BackgroundPrimaryDark}"
                                           BackgroundColor="Transparent"
                                           ReturnType="Search"
                                           ReturnCommand="{Binding SearchCommand}" />
                                </Border>
                                <Button Grid.Column="1"
                                        Text="Buscar"
                                        Command="{Binding SearchCommand}"
                                        Style="{StaticResource ButtonBold-XL-yellow}"
                                        FontSize="13"
                                        Padding="15,0"
                                        HeightRequest="44"
                                        VerticalOptions="Center"
                                        CornerRadius="8" />
                            </Grid>

                            <!-- Resultados de búsqueda -->
                            <VerticalStackLayout IsVisible="{Binding IsSearching}" Spacing="6">

                                <Button Text="✕  Cerrar búsqueda"
                                        Command="{Binding ClearSearchCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource TextSecondaryColorLight}"
                                        FontFamily="Montserrat-Medium"
                                        FontSize="12"
                                        HorizontalOptions="End"
                                        HeightRequest="32"
                                        Padding="0" />

                                <VerticalStackLayout Spacing="6"
                                                     BindableLayout.ItemsSource="{Binding SearchResults}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="dtos:ExerciseSummaryDto">
                                            <Border BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                                                    StrokeThickness="0"
                                                    Padding="12,10"
                                                    Margin="0,0,0,2">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8" />
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={x:Reference ManualRoutineBuilderPage}, Path=BindingContext.AddExerciseCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                                                        <Label Text="{Binding Name}"
                                                               Style="{StaticResource label-h3-white}"
                                                               LineBreakMode="WordWrap" />
                                                        <Label FontSize="11" Opacity="0.65">
                                                            <Label.FormattedText>
                                                                <FormattedString>
                                                                    <Span Text="{Binding Category}"
                                                                          FontFamily="Montserrat-Medium" />
                                                                    <Span Text=" · "
                                                                          FontFamily="Montserrat-Medium" />
                                                                    <Span Text="{Binding Level}"
                                                                          TextColor="{StaticResource TertiaryColor}"
                                                                          FontFamily="Montserrat-Medium" />
                                                                </FormattedString>
                                                            </Label.FormattedText>
                                                        </Label>
                                                    </VerticalStackLayout>
                                                    <!-- Badge + -->
                                                    <Border Grid.Column="1"
                                                            BackgroundColor="{StaticResource TertiaryColor}"
                                                            StrokeThickness="0"
                                                            WidthRequest="32"
                                                            HeightRequest="32"
                                                            VerticalOptions="Center">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="6" />
                                                        </Border.StrokeShape>
                                                        <Label Text="+"
                                                               TextColor="{StaticResource BackgroundPrimaryDark}"
                                                               FontSize="20"
                                                               FontFamily="Montserrat-Bold"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center"
                                                               InputTransparent="True" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <!-- Sin resultados -->
                                <Label Text="{Binding StatusMessage}"
                                       IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                       Style="{StaticResource label-p-white}"
                                       HorizontalTextAlignment="Center"
                                       Opacity="0.6" />
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                    <!-- Card: Ejercicios del día (siempre visible) -->
                    <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="15" Spacing="10">

                            <Label Text="Ejercicios del día"
                                   Style="{StaticResource label-h2-white}" />
                            <BoxView HeightRequest="1"
                                     BackgroundColor="{StaticResource TextSecondaryColorLight}"
                                     Opacity="0.15"
                                     HorizontalOptions="Fill" />

                            <!-- Lista de ejercicios añadidos -->
                            <VerticalStackLayout Spacing="0"
                                                 BindableLayout.ItemsSource="{Binding CurrentDay.Exercises}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ManualExerciseEntry">
                                        <VerticalStackLayout Spacing="10" Padding="0,8">

                                            <!-- Nombre + botón eliminar -->
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <Label Grid.Column="0"
                                                       Text="{Binding ExerciseName}"
                                                       Style="{StaticResource label-h3-white}"
                                                       LineBreakMode="WordWrap"
                                                       VerticalOptions="Center" />
                                                <Button Grid.Column="1"
                                                        Text="✕"
                                                        Command="{Binding Source={x:Reference ManualRoutineBuilderPage}, Path=BindingContext.RemoveExerciseCommand}"
                                                        CommandParameter="{Binding .}"
                                                        BackgroundColor="Transparent"
                                                        TextColor="{StaticResource TextSecondaryColorLight}"
                                                        FontSize="16"
                                                        Padding="0"
                                                        WidthRequest="32"
                                                        HeightRequest="32" />
                                            </Grid>

                                            <!-- Series · Reps · Descanso -->
                                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

                                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                    <Label Text="Series"
                                                           Style="{StaticResource label-p-white}"
                                                           FontSize="11"
                                                           Opacity="0.6" />
                                                    <Border BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                                                            StrokeThickness="0">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="6" />
                                                        </Border.StrokeShape>
                                                        <Entry Text="{Binding Sets, Mode=TwoWay}"
                                                               TextColor="{StaticResource TextPrimaryColorLight}"
                                                               BackgroundColor="Transparent"
                                                               Keyboard="Numeric"
                                                               HorizontalTextAlignment="Center"
                                                               FontFamily="Montserrat-Bold"
                                                               FontSize="15"
                                                               Margin="4,2" />
                                                    </Border>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                    <Label Text="Reps"
                                                           Style="{StaticResource label-p-white}"
                                                           FontSize="11"
                                                           Opacity="0.6" />
                                                    <Border BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                                                            StrokeThickness="0">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="6" />
                                                        </Border.StrokeShape>
                                                        <Entry Text="{Binding Reps, Mode=TwoWay}"
                                                               TextColor="{StaticResource TextPrimaryColorLight}"
                                                               BackgroundColor="Transparent"
                                                               HorizontalTextAlignment="Center"
                                                               FontFamily="Montserrat-Bold"
                                                               FontSize="15"
                                                               Margin="4,2" />
                                                    </Border>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Grid.Column="2" Spacing="4">
                                                    <Label Text="Descanso (s)"
                                                           Style="{StaticResource label-p-white}"
                                                           FontSize="11"
                                                           Opacity="0.6" />
                                                    <Border BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                                                            StrokeThickness="0">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="6" />
                                                        </Border.StrokeShape>
                                                        <Entry Text="{Binding RestSeconds, Mode=TwoWay}"
                                                               TextColor="{StaticResource TextPrimaryColorLight}"
                                                               BackgroundColor="Transparent"
                                                               Keyboard="Numeric"
                                                               HorizontalTextAlignment="Center"
                                                               FontFamily="Montserrat-Bold"
                                                               FontSize="15"
                                                               Margin="4,2" />
                                                    </Border>
                                                </VerticalStackLayout>

                                            </Grid>

                                            <BoxView HeightRequest="1"
                                                     BackgroundColor="{StaticResource TextSecondaryColorLight}"
                                                     Opacity="0.1"
                                                     HorizontalOptions="Fill" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <!-- Instrucción / estado vacío -->
                            <Label Text="Busca ejercicios arriba y tócalos para añadirlos al día"
                                   Style="{StaticResource label-p-white}"
                                   HorizontalTextAlignment="Center"
                                   Opacity="0.4"
                                   FontSize="12" />

                        </VerticalStackLayout>
                    </Border>

                    <!-- CTA: Guardar (siempre visible) -->
                    <Button Text="Guardar rutina"
                            Command="{Binding SaveRoutineCommand}"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                            Style="{StaticResource ButtonBold-XL-yellow}"
                            CornerRadius="{StaticResource CornerRadiusRectangle}"
                            HorizontalOptions="Fill" />

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
