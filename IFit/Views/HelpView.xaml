<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:components="clr-namespace:IFit.Views.Components"
             x:Class="IFit.Views.HelpView"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:HelpViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

        <!-- Header -->
        <Grid Grid.Row="0"
              Padding="15,48,15,20"
              ColumnDefinitions="44,*,44">

            <Button Grid.Column="0"
                    BackgroundColor="Transparent"
                    ImageSource="arrow.png"
                    Command="{Binding GoBackCommand}"
                    HeightRequest="44"
                    WidthRequest="44"
                    HorizontalOptions="Start"
                    VerticalOptions="Start" />

            <VerticalStackLayout Grid.Column="1"
                                 HorizontalOptions="Start"
                                 VerticalOptions="Start"
                                 Spacing="2">
                <Label Text="SOPORTE"
                       FontSize="11"
                       CharacterSpacing="2"
                       Opacity="0.5"
                       Style="{StaticResource label-p-white}"
                       HorizontalOptions="Start" />
                <Label Text="Ayuda"
                       Style="{StaticResource label-h1-white}"
                       HorizontalOptions="Start" />
            </VerticalStackLayout>
        </Grid>

        <!-- Contenido -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,0,20,16" Spacing="12">

                <!-- Card hero: descripción -->
                <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                        StrokeThickness="0"
                        Margin="0,0,0,4">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="12,14" Spacing="4">
                        <Label Text="Ticket de soporte"
                               Style="{StaticResource label-h2-white}" />
                        <Label Text="Describe tu problema y te responderemos por email en menos de 24 horas."
                               Style="{StaticResource label-p-white}"
                               Opacity="0.7"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Asunto -->
                <Label Text="Asunto"
                       Style="{StaticResource label-h3-white}"
                       Margin="0,8,0,0" />
                <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                        StrokeThickness="0"
                        Padding="12,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Entry Text="{Binding Subject}"
                           Placeholder="Resumen breve del problema"
                           PlaceholderColor="#888"
                           TextColor="{StaticResource TextPrimaryColorLight}"
                           BackgroundColor="Transparent"
                           HeightRequest="44" />
                </Border>

                <!-- Categoría -->
                <Label Text="Categoría"
                       Style="{StaticResource label-h3-white}"
                       Margin="0,8,0,0" />

                <!-- TECNICO -->
                <Border StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.BackgroundColor>
                        <StaticResource Key="BackgroundSecondaryDark" />
                    </Border.BackgroundColor>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding SelectedCategory}"
                                     Value="TECNICO">
                            <Setter Property="BackgroundColor"
                                    Value="{StaticResource BackgroundPrimaryDark}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                              CommandParameter="TECNICO" />
                    </Border.GestureRecognizers>
                    <Grid Padding="12,10" ColumnDefinitions="44,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource TertiaryColor}"
                                StrokeThickness="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="T"
                                   TextColor="{StaticResource BackgroundPrimaryDark}"
                                   FontFamily="Montserrat-Bold"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Técnico"
                                   Style="{StaticResource label-h3-white}" />
                            <Label Text="Errores, fallos o comportamientos inesperados de la app."
                                   Style="{StaticResource label-p-white}"
                                   FontSize="12"
                                   Opacity="0.65"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- RUTINA -->
                <Border StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.BackgroundColor>
                        <StaticResource Key="BackgroundSecondaryDark" />
                    </Border.BackgroundColor>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding SelectedCategory}"
                                     Value="RUTINA">
                            <Setter Property="BackgroundColor"
                                    Value="{StaticResource BackgroundPrimaryDark}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                              CommandParameter="RUTINA" />
                    </Border.GestureRecognizers>
                    <Grid Padding="12,10" ColumnDefinitions="44,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource TertiaryColor}"
                                StrokeThickness="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="R"
                                   TextColor="{StaticResource BackgroundPrimaryDark}"
                                   FontFamily="Montserrat-Bold"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Rutina"
                                   Style="{StaticResource label-h3-white}" />
                            <Label Text="Problemas con la generación o configuración de tu rutina de entrenamiento."
                                   Style="{StaticResource label-p-white}"
                                   FontSize="12"
                                   Opacity="0.65"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- CUENTA -->
                <Border StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.BackgroundColor>
                        <StaticResource Key="BackgroundSecondaryDark" />
                    </Border.BackgroundColor>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding SelectedCategory}"
                                     Value="CUENTA">
                            <Setter Property="BackgroundColor"
                                    Value="{StaticResource BackgroundPrimaryDark}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                              CommandParameter="CUENTA" />
                    </Border.GestureRecognizers>
                    <Grid Padding="12,10" ColumnDefinitions="44,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource TertiaryColor}"
                                StrokeThickness="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="C"
                                   TextColor="{StaticResource BackgroundPrimaryDark}"
                                   FontFamily="Montserrat-Bold"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Cuenta"
                                   Style="{StaticResource label-h3-white}" />
                            <Label Text="Acceso, verificación de email, perfil o datos de usuario."
                                   Style="{StaticResource label-p-white}"
                                   FontSize="12"
                                   Opacity="0.65"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- OTRO -->
                <Border StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.BackgroundColor>
                        <StaticResource Key="BackgroundSecondaryDark" />
                    </Border.BackgroundColor>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding SelectedCategory}"
                                     Value="OTRO">
                            <Setter Property="BackgroundColor"
                                    Value="{StaticResource BackgroundPrimaryDark}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                              CommandParameter="OTRO" />
                    </Border.GestureRecognizers>
                    <Grid Padding="12,10" ColumnDefinitions="44,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource TertiaryColor}"
                                StrokeThickness="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="O"
                                   TextColor="{StaticResource BackgroundPrimaryDark}"
                                   FontFamily="Montserrat-Bold"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Otro"
                                   Style="{StaticResource label-h3-white}" />
                            <Label Text="Sugerencias, comentarios o cualquier otra consulta."
                                   Style="{StaticResource label-p-white}"
                                   FontSize="12"
                                   Opacity="0.65"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Descripción -->
                <Label Text="Descripción"
                       Style="{StaticResource label-h3-white}"
                       Margin="0,8,0,0" />
                <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                        StrokeThickness="0"
                        Padding="12,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Editor Text="{Binding Message}"
                            Placeholder="Describe el problema con el mayor detalle posible"
                            PlaceholderColor="#888"
                            TextColor="{StaticResource TextPrimaryColorLight}"
                            BackgroundColor="Transparent"
                            HeightRequest="140"
                            AutoSize="Disabled" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- CTA fijo -->
        <Button Grid.Row="2"
                Text="Enviar ticket"
                Command="{Binding SendTicketCommand}"
                IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                Style="{StaticResource ButtonBold-XL-yellow}"
                Margin="20,8,20,16" />

        <!-- Loading overlay -->
        <components:LoadingOverlay Grid.RowSpan="3"
                                   IsLoading="{Binding IsLoading}"
                                   Message="Enviando ticket..." />

    </Grid>
</ContentPage>
