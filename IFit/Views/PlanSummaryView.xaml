<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:components="clr-namespace:IFit.Views.Components"
             xmlns:dtos="clr-namespace:IFit.Models.Dtos.AI"
             x:Class="IFit.Views.PlanSummaryView"
             Shell.NavBarIsVisible="False"
             Title="PlanSummaryView"
             BackgroundColor="{DynamicResource BackgroundPrimaryDark}">

    <ContentPage.BindingContext>
        <vm:PlanSummaryViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <!-- Raíz: Header arriba, contenido+botón abajo -->
    <Grid>
        <!-- Loading Overlay -->
        <components:LoadingOverlay IsLoading="{Binding IsLoading}"
                           Message="{Binding StatusMessage}"
                            ZIndex="999"/>

        <Grid RowDefinitions="Auto,*">

            <!-- ─── HEADER ─── -->
            <Grid Grid.Row="0"
          Background="{StaticResource CardPremiumYellowGradientColor}"
          RowDefinitions="Auto,Auto">

                <!-- Navbar -->
                <Grid Grid.Row="0" Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                    HorizontalOptions="Start"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    ImageSource="arrow.png"
                    Clicked="BackToHome" />

                    <Image Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Source="ifit_logo_white.png"
                   HeightRequest="20"
                   WidthRequest="120"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
                </Grid>

                <!-- Títulos -->
                <VerticalStackLayout Grid.Row="1"
                             Margin="15,0,15,20"
                             Spacing="6">
                    <Label Text="TUS RUTINAS"
                   FontSize="11"
                   CharacterSpacing="2"
                   Opacity="0.7"
                   Style="{StaticResource label-p-white}" />
                    <Label Text="Tus rutina"
                   Style="{StaticResource label-Title-white}" />
                    <Label Text="A continuación te presentamos tus rutinas"
                   Style="{StaticResource label-p-white}"
                   Opacity="0.8"
                   LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Grid>

            <!-- ─── CONTENT: ScrollView + Botón fijo ─── -->
            <Grid Grid.Row="1" RowDefinitions="*,Auto">

                <!-- ScrollView ocupa todo el espacio disponible -->
                <ScrollView Grid.Row="0">
                    <VerticalStackLayout Padding="15" Spacing="24">

                        <!-- SECCIÓN: Rutinas activas -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Rutinas activas"
                           Style="{StaticResource label-h2-white}" />

                            <CollectionView ItemsSource="{Binding ActiveRoutines}"
                                    SelectionMode="Single"
                                    SelectedItem="{Binding SelectedRoutine}">

                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical"
                                               ItemSpacing="10" />
                                </CollectionView.ItemsLayout>
                                
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="dtos:RoutineResponseDto">
                                        
                                        <Border Stroke="{StaticResource BackgroundPrimaryLight}"
                                        StrokeThickness="1">

                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroupList>
                                                    <VisualStateGroup x:Name="CommonStates">
                                                        <VisualState x:Name="Normal">
                                                            <VisualState.Setters>
                                                                <Setter Property="BackgroundColor" Value="{DynamicResource BackgroundPrimaryDark}" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="Selected">
                                                            <VisualState.Setters>
                                                                <Setter Property="BackgroundColor" Value="{DynamicResource BackgroundSecondaryDark}" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                    </VisualStateGroup>
                                                </VisualStateGroupList>
                                            </VisualStateManager.VisualStateGroups>
                                            
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <Border.Shadow>
                                                <Shadow Brush="Black"
                                                Opacity="0.2"
                                                Radius="10"
                                                Offset="0,3"/>
                                            </Border.Shadow>

                                            <Grid RowDefinitions="Auto,*">

                                                <!-- Accent strip -->
                                                <Border Grid.Row="0"
                                                StrokeThickness="0"
                                                Background="{DynamicResource CardPremiumYellowGradientColor}"
                                                HeightRequest="3"
                                                HorizontalOptions="Fill">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="14,14,0,0" />
                                                    </Border.StrokeShape>
                                                </Border>

                                                <!-- Contenido rutina -->
                                                <Grid Grid.Row="1"
                                              ColumnSpacing="12"
                                              Margin="12,10,12,12"
                                              ColumnDefinitions="48,1,*,Auto">

                                                    <!-- Días -->
                                                    <VerticalStackLayout Grid.Column="0"
                                                                 VerticalOptions="Center"
                                                                 HorizontalOptions="Center"
                                                                 Spacing="2">
                                                        <Label Text="DÍAS"
                                                       FontSize="9"
                                                       CharacterSpacing="1"
                                                       TextColor="White"
                                                       Opacity="0.5"
                                                       HorizontalTextAlignment="Center"/>
                                                        <Label Text="{Binding TrainingDays}"
                                                       Style="{DynamicResource label-Title-white}"
                                                       FontSize="28"
                                                       FontAttributes="Bold,Italic"
                                                       HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>

                                                    <!-- Separador -->
                                                    <BoxView Grid.Column="1"
                                                     BackgroundColor="{StaticResource TextSecondaryColorLight}"
                                                     Opacity="0.3"
                                                     VerticalOptions="Fill"
                                                     WidthRequest="1" />

                                                    <!-- Nombre + descripción + día actual -->
                                                    <VerticalStackLayout Grid.Column="2"
                                                                 VerticalOptions="Center"
                                                                 Margin="8,0,0,0"
                                                                 Spacing="4">

                                                        <Label Text="{Binding Description}"
                                                       Style="{DynamicResource label-h2-white}"
                                                       Opacity="0.7"
                                                       MaxLines="2"
                                                       LineBreakMode="TailTruncation"
                                                       FontSize="13"/>
                                                        <HorizontalStackLayout Spacing="4"
                                                                       IsVisible="{Binding CurrentDay, Converter={StaticResource IsNotNullConverter}}">
                                                            <Label Text="Día actual:"
                                                           Style="{DynamicResource label-p-white}"
                                                           Opacity="0.5"
                                                           FontSize="11"/>
                                                            <Label Text="{Binding CurrentDay}"
                                                           Style="{DynamicResource label-p-white}"
                                                           FontSize="11"
                                                           FontAttributes="Bold"/>
                                                        </HorizontalStackLayout>
                                                    </VerticalStackLayout>

                                                    <!-- Badge activa -->
                                                    <Border Grid.Column="3"
                                                    StrokeThickness="0"
                                                    VerticalOptions="Start"
                                                    Padding="6,3">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="8" />
                                                        </Border.StrokeShape>
                                                        <Border.Background>
                                                            <SolidColorBrush Color="#4CAF50" />
                                                        </Border.Background>
                                                        <Label Text="ACTIVA"
                                                       FontSize="9"
                                                       CharacterSpacing="1"
                                                       TextColor="White"
                                                       FontAttributes="Bold"/>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <!-- SECCIÓN: Todas las rutinas -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Todas las rutinas"
                           Style="{StaticResource label-h2-white}" />

                            <CollectionView ItemsSource="{Binding AllRoutines}"
                                    SelectionMode="Single"
                                    SelectedItem="{Binding SelectedRoutine}">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical"
                                               ItemSpacing="10" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="dtos:RoutineResponseDto">
                                        <Border Stroke="{StaticResource BackgroundPrimaryLight}"
                                        StrokeThickness="1">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <Border.Shadow>
                                                <Shadow Brush="Black"
                                                Opacity="0.2"
                                                Radius="10"
                                                Offset="0,3"/>
                                            </Border.Shadow>

                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroupList>
                                                    <VisualStateGroup x:Name="CommonStates">
                                                        <VisualState x:Name="Normal">
                                                            <VisualState.Setters>
                                                                <Setter Property="BackgroundColor" Value="{DynamicResource BackgroundPrimaryDark}" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="Selected">
                                                            <VisualState.Setters>
                                                                <Setter Property="BackgroundColor" Value="{DynamicResource BackgroundSecondaryDark}" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                    </VisualStateGroup>
                                                </VisualStateGroupList>
                                            </VisualStateManager.VisualStateGroups>

                                            <Grid RowDefinitions="Auto,*">

                                                <!-- Accent strip -->
                                                <Border Grid.Row="0"
                                                StrokeThickness="0"
                                                Background="{DynamicResource CardPremiumYellowGradientColor}"
                                                HeightRequest="3"
                                                HorizontalOptions="Fill">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="14,14,0,0" />
                                                    </Border.StrokeShape>
                                                </Border>

                                                <!-- Contenido rutina -->
                                                <Grid Grid.Row="1"
                                              ColumnSpacing="12"
                                              Margin="12,10,12,12"
                                              ColumnDefinitions="48,1,*,Auto">

                                                    <!-- Días -->
                                                    <VerticalStackLayout Grid.Column="0"
                                                                 VerticalOptions="Center"
                                                                 HorizontalOptions="Center"
                                                                 Spacing="2">
                                                        <Label Text="DÍAS"
                                                       FontSize="9"
                                                       CharacterSpacing="1"
                                                       TextColor="White"
                                                       Opacity="0.5"
                                                       HorizontalTextAlignment="Center"/>
                                                        <Label Text="{Binding TrainingDays}"
                                                       Style="{DynamicResource label-Title-white}"
                                                       FontSize="28"
                                                       FontAttributes="Bold,Italic"
                                                       HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>

                                                    <!-- Separador -->
                                                    <BoxView Grid.Column="1"
                                                     BackgroundColor="{StaticResource TextSecondaryColorLight}"
                                                     Opacity="0.3"
                                                     VerticalOptions="Fill"
                                                     WidthRequest="1" />

                                                    <!-- Nombre + descripción + día actual -->
                                                    <VerticalStackLayout Grid.Column="2"
                                                                 VerticalOptions="Center"
                                                                 Margin="8,0,0,0"
                                                                 Spacing="4">

                                                        <Label Text="{Binding Description}"
                                                       Style="{DynamicResource label-h2-white}"
                                                       Opacity="0.7"
                                                       MaxLines="2"
                                                        LineBreakMode="TailTruncation"
                                                       FontSize="13"/>
                                                        <HorizontalStackLayout Spacing="4"
                                                                       IsVisible="{Binding CurrentDay, Converter={StaticResource IsNotNullConverter}}">
                                                            <Label Text="Día actual:"
                                                           Style="{DynamicResource label-p-white}"
                                                           Opacity="0.5"
                                                           FontSize="11"/>
                                                            <Label Text="{Binding CurrentDay}"
                                                           Style="{DynamicResource label-p-white}"
                                                           FontSize="11"
                                                           FontAttributes="Bold"/>
                                                        </HorizontalStackLayout>
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Botón fijo en la parte inferior -->
                <Button Grid.Row="1"
                Margin="15,10,15,20"
                Text="Generar nueva rutina"
                Style="{StaticResource ButtonBold-XL-dark-yellow}"
                CornerRadius="{StaticResource CornerRadiusRectangle}"
                Command="{Binding GenerateNewRoutineCommand}"/>

            </Grid>

        </Grid>

    </Grid>
</ContentPage>