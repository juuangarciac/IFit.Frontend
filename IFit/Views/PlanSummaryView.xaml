<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:components="clr-namespace:IFit.Views.Components"
             xmlns:dtos="clr-namespace:IFit.Models.Dtos.AI"
             x:Class="IFit.Views.PlanSummaryView"
             x:Name="PlanSummaryPage"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:PlanSummaryViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <Grid>
        <!-- Loading Overlay -->
        <components:LoadingOverlay IsLoading="{Binding IsLoading}"
                                   Message="{Binding StatusMessage}"
                                   ZIndex="999"/>

        <Grid RowDefinitions="Auto,*">

            <!-- ─── HEADER ─── -->
            <Grid Grid.Row="0"
                  Background="{StaticResource CardPremiumYellowGradientColor}"
                  RowDefinitions="Auto,Auto">

                <!-- Navbar -->
                <Grid Grid.Row="0" Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            HorizontalOptions="Start"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent"
                            ImageSource="arrow.png"
                            Clicked="BackToHome" />
                    <Image Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Source="ifit_logo_white.png"
                           HeightRequest="20"
                           WidthRequest="120"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Títulos -->
                <VerticalStackLayout Grid.Row="1"
                                     Margin="15,0,15,20"
                                     Spacing="6">
                    <Label Text="TUS RUTINAS"
                           FontSize="11"
                           CharacterSpacing="2"
                           Opacity="0.7"
                           Style="{StaticResource label-p-white}" />
                    <Label Text="Tu rutina"
                           Style="{StaticResource label-Title-white}" />
                    <Label Text="A continuación te presentamos tus rutinas"
                           Style="{StaticResource label-p-white}"
                           Opacity="0.8"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Grid>

            <!-- ─── CONTENT ─── -->
            <Grid Grid.Row="1" RowDefinitions="*,Auto">

                <ScrollView Grid.Row="0">
                    <VerticalStackLayout Padding="15" Spacing="10">

                        <Label Text="Tus rutinas"
                               Style="{StaticResource label-h2-white}"
                               Margin="0,0,0,2" />

                        <CollectionView ItemsSource="{Binding AllRoutines}"
                                        SelectionMode="Single"
                                        SelectedItem="{Binding SelectedRoutine}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical"
                                                   ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="dtos:RoutineResponseDto">
                                    <Border StrokeThickness="0"
                                            HorizontalOptions="Fill"
                                            HeightRequest="80">
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroupList>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="{StaticResource BackgroundSecondaryDark}" />
                                                        </VisualState.Setters>
                                                    </VisualState>
                                                    <VisualState x:Name="Selected">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="{StaticResource BackgroundPrimaryDark}" />
                                                        </VisualState.Setters>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateGroupList>
                                        </VisualStateManager.VisualStateGroups>
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>

                                        <Grid Padding="12,10"
                                              ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">

                                            <!-- Descripción + metadatos -->
                                            <VerticalStackLayout Grid.Column="0"
                                                                 VerticalOptions="Center"
                                                                 Spacing="4">
                                                <Label Text="{Binding Description}"
                                                       Style="{StaticResource label-h2-white}"
                                                       MaxLines="2"
                                                       LineBreakMode="TailTruncation" />
                                                <HorizontalStackLayout Spacing="6">
                                                    <Label Text="{Binding TrainingDays, StringFormat='{0} días'}"
                                                           Style="{StaticResource label-p-white}"
                                                           Opacity="0.7"
                                                           FontSize="12" />
                                                    <Label Text="·"
                                                           Style="{StaticResource label-p-white}"
                                                           Opacity="0.4"
                                                           FontSize="12"
                                                           IsVisible="{Binding CurrentDay, Converter={StaticResource IsNotNullConverter}}" />
                                                    <Label Text="{Binding CurrentDay, StringFormat='Día {0}'}"
                                                           Style="{StaticResource label-p-white}"
                                                           Opacity="0.7"
                                                           FontSize="12"
                                                           IsVisible="{Binding CurrentDay, Converter={StaticResource IsNotNullConverter}}" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <!-- Badges -->
                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center"
                                                                 Spacing="4">

                                                <!-- ACTIVA -->
                                                <Border StrokeThickness="0"
                                                        Padding="8,4"
                                                        IsVisible="{Binding IsActive}"
                                                        BackgroundColor="{StaticResource TertiaryColor}">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="6" />
                                                    </Border.StrokeShape>
                                                    <Label Text="ACTIVA"
                                                           FontSize="9"
                                                           CharacterSpacing="1"
                                                           TextColor="{StaticResource BackgroundPrimaryDark}"
                                                           FontFamily="Montserrat-Bold" />
                                                </Border>

                                                <!-- ACTIVAR -->
                                                <Border StrokeThickness="0"
                                                        Padding="8,4"
                                                        IsVisible="{Binding IsActive, Converter={StaticResource InvertedBoolConverter}}"
                                                        BackgroundColor="{StaticResource TertiaryColor}">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="6" />
                                                    </Border.StrokeShape>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference PlanSummaryPage}, Path=BindingContext.ActivateRoutineCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Border.GestureRecognizers>
                                                    <Label Text="ACTIVAR"
                                                           FontSize="9"
                                                           CharacterSpacing="1"
                                                           TextColor="{StaticResource BackgroundPrimaryDark}"
                                                           FontFamily="Montserrat-Bold"
                                                           InputTransparent="True" />
                                                </Border>

                                            </VerticalStackLayout>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Botón fijo -->
                <Button Grid.Row="1"
                        Margin="15,10,15,20"
                        Text="Generar nueva rutina"
                        Style="{StaticResource ButtonBold-XL-dark-yellow}"
                        CornerRadius="{StaticResource CornerRadiusRectangle}"
                        Command="{Binding GenerateNewRoutineCommand}" />

            </Grid>

        </Grid>
    </Grid>
</ContentPage>
