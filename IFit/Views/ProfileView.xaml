<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:views="clr-namespace:IFit.Views.Templates"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:components="clr-namespace:IFit.Views.Components"
             x:Class="IFit.Views.ProfileView"
             x:Name="ProfilePage"
             Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <ContentPage.BindingContext>
        <vm:ProfileViewModel />
    </ContentPage.BindingContext>

    <Grid Background="{DynamicResource PremiumGradient}"
          RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              Padding="20,50,20,15"
              ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                 HorizontalOptions="Start"
                 VerticalOptions="Center"
                 BackgroundColor="Transparent"
                 ImageSource="arrow.png"
                 Command="{Binding GoToHomeCommand}" />

            <Label Grid.Column="1"
                   Text="Mi perfil"
                   Style="{DynamicResource label-h1-white}"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1"
                    Margin="15,0">
            <VerticalStackLayout Spacing="15"
                                 Padding="0,10,0,20">

                <!-- Avatar + nombre -->
                <Border BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                    </Border.StrokeShape>

                    <Grid ColumnSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              HeightRequest="65"
                              WidthRequest="65"
                              VerticalOptions="Center">

                            <Border HeightRequest="65"
                                    WidthRequest="65"
                                    BackgroundColor="{DynamicResource BackgroundSecondaryDark}"
                                    StrokeThickness="2"
                                    Stroke="{DynamicResource TertiaryColor}">
                                <Border.StrokeShape>
                                    <Ellipse />
                                </Border.StrokeShape>
                                <Image Source="profile_icon_white.png"
                                       HeightRequest="34"
                                       WidthRequest="34"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <Grid Grid.Column="1"
                              RowSpacing="4"
                              VerticalOptions="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0"
                                   Text="{Binding UserName}"
                                   Style="{DynamicResource label-h2-white}"
                                   LineBreakMode="TailTruncation" />

                            <Label Grid.Row="1"
                                   Text="{Binding UserEmail}"
                                   Style="{DynamicResource label-p-white}"
                                   Opacity="0.7"
                                   LineBreakMode="TailTruncation" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Información del perfil -->
                <Border BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="0">

                        <!-- Título -->
                        <Label Text="Información"
                               Style="{DynamicResource label-h2-white}"
                               Margin="0,0,0,14" />

                        <BoxView HeightRequest="1"
                                 Color="{DynamicResource QuaternaryColor}"
                                 Opacity="0.3"
                                 Margin="0,0,0,14" />

                        <!-- ── NIVEL DE EXPERIENCIA ── -->
                        <!-- Cabecera desplegable -->
                        <Grid ColumnSpacing="10"
                              Margin="0,0,0,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleExperiencePanelCommand}" />
                            </Grid.GestureRecognizers>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0"
                                   Text="Nivel de experiencia"
                                   Style="{DynamicResource label-p-white}"
                                   Opacity="0.7"
                                   VerticalOptions="Center" />

                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="6"
                                                   VerticalOptions="Center">
                                <Label Text="{Binding ExperienceLevel}"
                                       Style="{DynamicResource label-p-white}" />
                                <Label Text="▾"
                                       Style="{DynamicResource label-p-white}"
                                       Opacity="0.6">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsExperiencePanelExpanded}"
                                                     Value="True">
                                            <Setter Property="Text" Value="▴" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </HorizontalStackLayout>
                        </Grid>

                        <!-- Lista desplegable de niveles -->
                        <VerticalStackLayout IsVisible="{Binding IsExperiencePanelExpanded}"
                                             Spacing="8"
                                             Margin="0,0,0,14">
                            <BindableLayout.ItemsSource>
                                <Binding Path="ExperienceOptions" />
                            </BindableLayout.ItemsSource>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeThickness="0"
                                            Padding="12,10">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference ProfilePage}, Path=BindingContext.SelectExperienceLevelCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding IsActive}"
                                                         Value="True">
                                                <Setter Property="BackgroundColor"
                                                        Value="{StaticResource BackgroundSecondaryDark}" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding IsActive}"
                                                         Value="False">
                                                <Setter Property="BackgroundColor"
                                                        Value="{StaticResource PrimaryColorLightOpacity}" />
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <VerticalStackLayout Grid.Column="0"
                                                                 Spacing="3"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Name}"
                                                       Style="{DynamicResource label-h3-white}" />
                                                <Label Text="{Binding Description}"
                                                       Style="{DynamicResource label-p-white}"
                                                       FontSize="12"
                                                       Opacity="0.6"
                                                       LineBreakMode="WordWrap" />
                                            </VerticalStackLayout>

                                            <!-- Badge ACTIVO -->
                                            <Border Grid.Column="1"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{StaticResource TertiaryColor}"
                                                    Padding="8,4"
                                                    VerticalOptions="Center"
                                                    IsVisible="{Binding IsActive}">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="6" />
                                                </Border.StrokeShape>
                                                <Label Text="ACTIVO"
                                                       FontFamily="Montserrat-Bold"
                                                       FontSize="10"
                                                       CharacterSpacing="1"
                                                       TextColor="{StaticResource BackgroundPrimaryDark}" />
                                            </Border>

                                            <!-- Label Seleccionar -->
                                            <Label Grid.Column="1"
                                                   Text="Seleccionar"
                                                   FontSize="12"
                                                   FontFamily="Montserrat-Medium"
                                                   TextColor="{StaticResource TertiaryColor}"
                                                   VerticalOptions="Center"
                                                   IsVisible="{Binding IsActive, Converter={StaticResource InvertedBoolConverter}}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Color="{DynamicResource QuaternaryColor}"
                                 Opacity="0.15"
                                 Margin="0,0,0,14" />

                        <!-- ── COACH IA ── -->
                        <!-- Cabecera desplegable -->
                        <Grid ColumnSpacing="10"
                              Margin="0,0,0,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleCoachPanelCommand}" />
                            </Grid.GestureRecognizers>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0"
                                   Text="Coach IA"
                                   Style="{DynamicResource label-p-white}"
                                   Opacity="0.7"
                                   VerticalOptions="Center" />

                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="6"
                                                   VerticalOptions="Center">
                                <Label Text="{Binding CoachModel}"
                                       Style="{DynamicResource label-p-white}" />
                                <Label Text="▾"
                                       Style="{DynamicResource label-p-white}"
                                       Opacity="0.6">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsCoachPanelExpanded}"
                                                     Value="True">
                                            <Setter Property="Text" Value="▴" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </HorizontalStackLayout>
                        </Grid>

                        <!-- Lista desplegable de coaches -->
                        <VerticalStackLayout IsVisible="{Binding IsCoachPanelExpanded}"
                                             Spacing="8"
                                             Margin="0,0,0,14">
                            <BindableLayout.ItemsSource>
                                <Binding Path="CoachOptions" />
                            </BindableLayout.ItemsSource>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeThickness="0"
                                            Padding="12,10">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference ProfilePage}, Path=BindingContext.SelectCoachCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding IsActive}"
                                                         Value="True">
                                                <Setter Property="BackgroundColor"
                                                        Value="{StaticResource BackgroundSecondaryDark}" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding IsActive}"
                                                         Value="False">
                                                <Setter Property="BackgroundColor"
                                                        Value="{StaticResource PrimaryColorLightOpacity}" />
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <VerticalStackLayout Grid.Column="0"
                                                                 Spacing="3"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Name}"
                                                       Style="{DynamicResource label-h3-white}" />
                                                <Label Text="{Binding Description}"
                                                       Style="{DynamicResource label-p-white}"
                                                       FontSize="12"
                                                       Opacity="0.6"
                                                       LineBreakMode="WordWrap" />
                                            </VerticalStackLayout>

                                            <!-- Badge ACTIVO -->
                                            <Border Grid.Column="1"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{StaticResource TertiaryColor}"
                                                    Padding="8,4"
                                                    VerticalOptions="Center"
                                                    IsVisible="{Binding IsActive}">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="6" />
                                                </Border.StrokeShape>
                                                <Label Text="ACTIVO"
                                                       FontFamily="Montserrat-Bold"
                                                       FontSize="10"
                                                       CharacterSpacing="1"
                                                       TextColor="{StaticResource BackgroundPrimaryDark}" />
                                            </Border>

                                            <!-- Label Seleccionar -->
                                            <Label Grid.Column="1"
                                                   Text="Seleccionar"
                                                   FontSize="12"
                                                   FontFamily="Montserrat-Medium"
                                                   TextColor="{StaticResource TertiaryColor}"
                                                   VerticalOptions="Center"
                                                   IsVisible="{Binding IsActive, Converter={StaticResource InvertedBoolConverter}}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Color="{DynamicResource QuaternaryColor}"
                                 Opacity="0.15"
                                 Margin="0,0,0,14" />

                        <!-- Miembro desde -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Text="Miembro desde"
                                   Style="{DynamicResource label-p-white}"
                                   Opacity="0.7" />
                            <Label Grid.Column="1"
                                   Text="{Binding MemberSince}"
                                   Style="{DynamicResource label-p-white}"
                                   HorizontalOptions="End" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Cerrar sesión -->
                <Button Text="Cerrar sesión"
                        Style="{DynamicResource ButtonBold-XL-dark-white}"
                        CornerRadius="6"
                        BorderColor="{DynamicResource BorderButtonLightColor}"
                        BorderWidth="0.25"
                        Command="{Binding LogoutCommand}" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer -->
        <views:HomeFooterView Grid.Row="2" />

        <components:LoadingOverlay Grid.RowSpan="3"
                                   IsLoading="{Binding IsLoading}"
                                   Message="{Binding StatusMessage}" />
    </Grid>
</ContentPage>
