<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:cal="clr-namespace:Plugin.Maui.Calendar.Controls;assembly=Plugin.Maui.Calendar"
             xmlns:vm="clr-namespace:IFit.ViewModels.Templates"
             x:Class="IFit.Views.Templates.HomeHeader">
    <ContentView.BindingContext>
        <vm:HomeHeaderViewModel />
    </ContentView.BindingContext>
    <!-- Header -->
    <Border 
         BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
         Stroke="{DynamicResource BackgroundPrimaryDark}"
         StrokeThickness="0"
         StrokeShape="RoundRectangle 0, 0, 10, 10">
        <Border.Shadow>
            <Shadow Opacity="0.4"
                 Brush="Black"
                 Offset="5, 5" />
        </Border.Shadow>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Profile/Notif/Icon/Calendar -->
            <Grid Grid.Row="0"
                    Margin="10, 15, 15, 0"
                    ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Profile Icon -->
                <Image Grid.Column="0"
                   Source="profile_icon_white.png"
                   Style="{DynamicResource navbar_image}"/>

                <!-- Notif Icon -->
                <Image Grid.Column="1"
                   Source="notification_icon_white.png"
                   Style="{DynamicResource navbar_image}"/>

                <!-- ifit logo -->
                <Image Grid.Column="2"
                   Source="ifit_logo_white.png"
                   HeightRequest="20"
                   WidthRequest="120"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />

                <!-- Calendar Icon -->
                <Image Grid.Column="3"
                   Source="calendar_icon_white.png"
                   Style="{DynamicResource navbar_image}"/>
            </Grid>

            <!-- Calendar -->
            <cal:Calendar Grid.Row="1"
                   Style="{Binding SelectedCalendarStyle}" >
            </cal:Calendar>
            
            <!--Expand Calendar Scroll -->
            <Image Grid.Row="2"
                   Source="arrow_icon_white.png"
                   Style="{DynamicResource navbar_image}">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ExpandCalendarCommand}" />
                </Image.GestureRecognizers>
            </Image>
            
        </Grid>
    </Border>
</ContentView>