<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:components="clr-namespace:IFit.Views.Components"
             x:Class="IFit.Views.ExerciseDetailView"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:ExerciseDetailViewModel />
    </ContentPage.BindingContext>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Loading overlay -->
        <components:LoadingOverlay Grid.RowSpan="2"
                                   IsLoading="{Binding IsLoading}"
                                   Message="{Binding StatusMessage}"
                                   ZIndex="999" />

        <!-- Row 0: Header fijo -->
        <Grid Grid.Row="0"
              Padding="15,50,15,10"
              ColumnSpacing="12"
              ColumnDefinitions="Auto,*">

            <Button Grid.Column="0"
              HorizontalOptions="Start"
              VerticalOptions="Center"
              BackgroundColor="Transparent"
              ImageSource="arrow.png"
              Command="{Binding GoBackCommand}" />

            <Label Grid.Column="1"
                   Text="{Binding Exercise.Name}"
                   Style="{StaticResource label-h1-white}"
                   VerticalOptions="Center"
                   LineBreakMode="WordWrap" />
        </Grid>

        <!-- Row 1: Scroll -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- Estado de error -->
                <VerticalStackLayout IsVisible="{Binding HasError}"
                                     Spacing="16"
                                     Padding="30"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Margin="0,60,0,0">

                    <Label Text="&#x26A0;"
                           FontSize="48"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource TertiaryColor}" />

                    <Label Text="{Binding ErrorMessage}"
                           Style="{StaticResource label-p-white}"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           Opacity="0.8" />

                    <Button Text="Reintentar"
                            Command="{Binding RetryCommand}"
                            Style="{StaticResource ButtonBold-XL-dark-yellow}"
                            CornerRadius="{StaticResource CornerRadiusRectangle}"
                            HorizontalOptions="Center"
                            Padding="30,0" />
                </VerticalStackLayout>

                <!-- Galería de imágenes -->
                <CarouselView x:Name="PhotoCarousel"
                              ItemsSource="{Binding FullImageUrls}"
                              IsVisible="{Binding HasImages}"
                              HeightRequest="240"
                              IndicatorView="PhotoIndicator"
                              Loop="False"
                              Margin="0,8,0,0">
                    <CarouselView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                                    StrokeThickness="0"
                                    Margin="15,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="{StaticResource CornerRadiusRectangle}" />
                                </Border.StrokeShape>
                                <Image Source="{Binding .}"
                                       Aspect="AspectFit" />
                            </Border>
                        </DataTemplate>
                    </CarouselView.ItemTemplate>
                </CarouselView>

                <!-- Indicador de página (dots) -->
                <IndicatorView x:Name="PhotoIndicator"
                               IsVisible="{Binding HasImages}"
                               IndicatorColor="{StaticResource TextSecondaryColorLight}"
                               SelectedIndicatorColor="{StaticResource TertiaryColor}"
                               HorizontalOptions="Center"
                               Margin="0,8,0,4" />

                <!-- Contenido del ejercicio -->
                <VerticalStackLayout Spacing="12"
                                     Padding="15,8,15,30"
                                     IsVisible="{Binding HasError, Converter={StaticResource InvertedBoolConverter}}">

                    <!-- Card: metadatos del ejercicio -->
                    <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource CornerRadiusRectangle}" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Padding="15" Spacing="10">

                            <Label Text="{Binding Exercise.Name}"
                                   Style="{StaticResource label-h1-white}"
                                   LineBreakMode="WordWrap" />

                            <!-- Badges: Nivel · Categoría · Equipamiento -->
                            <HorizontalStackLayout Spacing="8">

                                <Border BackgroundColor="{StaticResource TertiaryColor}"
                                        StrokeThickness="0" Padding="10,5">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                    <Label Text="{Binding Exercise.Level}"
                                           TextColor="{StaticResource BackgroundPrimaryDark}"
                                           FontSize="12" FontFamily="Montserrat-Medium" />
                                </Border>

                                <Border BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                                        StrokeThickness="0" Padding="10,5">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                    <Label Text="{Binding Exercise.Category}"
                                           TextColor="{StaticResource TextSecondaryColorLight}"
                                           FontSize="12" FontFamily="Montserrat-Medium" />
                                </Border>

                                <Border BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                                        StrokeThickness="0" Padding="10,5">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                    <Label Text="{Binding Exercise.Equipment}"
                                           TextColor="{StaticResource TextPrimaryColorLight}"
                                           FontSize="12" FontFamily="Montserrat-Medium" />
                                </Border>

                            </HorizontalStackLayout>

                            <!-- Tipo de fuerza y mecánica -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12"
                                  IsVisible="{Binding HasForce}">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="Tipo de fuerza"
                                           Style="{StaticResource label-p-white}"
                                           FontSize="11" Opacity="0.55" />
                                    <Label Text="{Binding Exercise.Force}"
                                           Style="{StaticResource label-p-white}"
                                           FontSize="13" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                     IsVisible="{Binding HasMechanic}">
                                    <Label Text="Mecánica"
                                           Style="{StaticResource label-p-white}"
                                           FontSize="11" Opacity="0.55" />
                                    <Label Text="{Binding Exercise.Mechanic}"
                                           Style="{StaticResource label-p-white}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                    <!-- Card: músculos -->
                    <Border BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource CornerRadiusRectangle}" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Padding="15" Spacing="10">

                            <Label Text="Músculos" Style="{StaticResource label-h2-white}" />

                            <BoxView HeightRequest="1"
                                     BackgroundColor="{StaticResource TextSecondaryColorLight}"
                                     Opacity="0.25" HorizontalOptions="Fill" />

                            <Label Text="Primarios"
                                   Style="{StaticResource label-p-white}"
                                   FontSize="12" Opacity="0.6" />

                            <!-- Músculos primarios: FlexLayout porque el número de items es dinámico -->
                            <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                        BindableLayout.ItemsSource="{Binding Exercise.PrimaryMuscles}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border BackgroundColor="{StaticResource TertiaryColor}"
                                                StrokeThickness="0" Margin="0,3,8,3" Padding="12,5">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                            <Label Text="{Binding .}"
                                                   TextColor="{StaticResource BackgroundPrimaryDark}"
                                                   FontSize="12" FontFamily="Montserrat-Medium" />
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>

                            <Label Text="Secundarios"
                                   Style="{StaticResource label-p-white}"
                                   FontSize="12" Opacity="0.6"
                                   IsVisible="{Binding HasSecondaryMuscles}"
                                   Margin="0,4,0,0" />

                            <!-- Músculos secundarios: FlexLayout por el mismo motivo -->
                            <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                        IsVisible="{Binding HasSecondaryMuscles}"
                                        BindableLayout.ItemsSource="{Binding Exercise.SecondaryMuscles}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                                                StrokeThickness="0"
                                                Margin="0,3,8,3" Padding="12,5">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                            <Label Text="{Binding .}"
                                                   TextColor="{StaticResource TextSecondaryColorLight}"
                                                   FontSize="12" FontFamily="Montserrat-Medium" />
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>

                        </VerticalStackLayout>
                    </Border>

                    <!-- Card: instrucciones -->
                    <Border IsVisible="{Binding HasInstructions}"
                            BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource CornerRadiusRectangle}" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Padding="15" Spacing="10">

                            <Label Text="Instrucciones" Style="{StaticResource label-h2-white}" />

                            <BoxView HeightRequest="1"
                                     BackgroundColor="{StaticResource TextSecondaryColorLight}"
                                     Opacity="0.25" HorizontalOptions="Fill" />

                            <VerticalStackLayout Spacing="14"
                                                 BindableLayout.ItemsSource="{Binding NumberedInstructions}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:InstructionItem">
                                        <Grid ColumnDefinitions="26,*" ColumnSpacing="10">

                                            <Border Grid.Column="0"
                                                    BackgroundColor="{StaticResource TertiaryColor}"
                                                    StrokeThickness="0"
                                                    HeightRequest="24"
                                                    WidthRequest="24"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="Start">
                                                <Border.StrokeShape>
                                                    <Ellipse />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Number}"
                                                       TextColor="{StaticResource BackgroundPrimaryDark}"
                                                       FontSize="12"
                                                       FontFamily="Montserrat-Bold"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>

                                            <Label Grid.Column="1"
                                                   Text="{Binding Text}"
                                                   Style="{StaticResource label-p-white}"
                                                   LineBreakMode="WordWrap"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
