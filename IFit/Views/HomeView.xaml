<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:IFit.Views.Templates"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:items="clr-namespace:IFit.Resources.Items"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:components="clr-namespace:IFit.Views.Components"
             x:Class="IFit.Views.HomeView"
             Shell.NavBarIsVisible="False">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>
    <ContentPage.BindingContext>
        <vm:HomeViewModel />
    </ContentPage.BindingContext>
    <Grid Background="{DynamicResource PremiumGradient}"
          RowSpacing="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <views:HomeHeader Grid.Row="0" />

        <!-- Home Body -->
        <Grid Grid.Row="1"
      VerticalOptions="Fill"
      HorizontalOptions="Center"
      Margin="20,0"
      RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Carrousel -->
            <CollectionView Grid.Row="0"
        ItemsSource="{Binding InformationCarrousel}"
        SelectionMode="None"
        ItemsLayout="HorizontalList">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="items:IFitCard">
                        <Border StrokeThickness="2"
            Stroke="{DynamicResource BackgroundPrimaryDark}"
            BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
            Padding="5"
            Margin="5,0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                            </Border.StrokeShape>

                            <Border.Shadow>
                                <Shadow Brush="{DynamicResource BackgroundSecondaryDark}"
                    Opacity="0.35"
                    Radius="{DynamicResource CornerRadiusRectangle}" />
                            </Border.Shadow>

                            <!-- Card -->
                            <Grid Margin="10"
              RowSpacing="5"
              BackgroundColor="Transparent"
              WidthRequest="315">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Icon + Title -->
                                <Grid Grid.Row="0"
                  ColumnSpacing="5"
                  VerticalOptions="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0" 
                       Source="{Binding ImageSource}"
                       HeightRequest="25"
                       WidthRequest="25" />

                                    <Label Grid.Column="1"
                       Text="{Binding Title}"
                       FontSize="16"
                       Style="{DynamicResource label-h1-white}" />
                                </Grid>

                                <!-- Text -->
                                <Label Grid.Row="1"
                   Text="{Binding TextBody}"
                   Style="{DynamicResource label-p-white}" />

                                <!-- Buttons -->
                                <Grid Grid.Row="2"
                  ColumnSpacing="10"
                  Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Accept -->
                                    <Button Grid.Column="0"
                        Text="{Binding TextButtonAccept}"
                        FontSize="14"
                        FontAttributes="Italic"
                        Style="{DynamicResource ButtonBold-XL-dark-yellow}" 
                        HorizontalOptions="Fill"
                        VerticalOptions="Center"/>

                                    <!-- Decline -->
                                    <Button Grid.Column="1"
                        Text="{Binding TextButtonDecline}"
                        TextColor="{DynamicResource TextPrimaryColorLight}"
                        Style="{DynamicResource BasicButton}"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Fill"
                        VerticalOptions="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Entrenamientos de hoy -->
            <ScrollView Grid.Row="1"
                VerticalOptions="Fill">
                
                <Grid RowSpacing="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <Label Grid.Row="0"
                   Text="Entrenamiento de hoy"
                   Style="{DynamicResource label-h1-white}"/>


                    <!-- Card con informacion del entrenamiento de hoy -->
                    <Border Grid.Row="1"
                            StrokeThickness="0"
                            IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                            BackgroundColor="{DynamicResource BackgroundPrimaryDark}">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>

                        <Grid>
                            <!-- Contenido del card -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Barra degradado verde izquierda -->
                                <Border Grid.Column="0"
                                        StrokeThickness="0"
                                        Margin="0"
                                        Background="{DynamicResource CardPremiumGradientColor}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8, 0, 8, 0"/>
                                    </Border.StrokeShape>
                                </Border>

                                <!-- Contenido -->
                                <Grid Grid.Column="1"
                                      RowSpacing="10"
                                      Padding="12,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Column="0"
                                           Text="{Binding TrainingDayDto.DayName}"
                                           Style="{DynamicResource label-h2-white}"/>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="25"/>
                                        </Grid.ColumnDefinitions>

                                        <Label Grid.Column="0"
                                               VerticalOptions="Center"
                                               Text="{Binding TrainingDayDto.Description}"
                                               Style="{DynamicResource label-p-white}"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation" />

                                        <Image Grid.Column="1"
                                               VerticalOptions="Center"
                                               HorizontalOptions="End"
                                               Source="insignia_ifit.png"
                                               MaximumHeightRequest="25"
                                               MaximumWidthRequest="25" />
                                    </Grid>
                                </Grid>
                            </Grid>

                            <!-- Botón transparente superpuesto — ripple nativo Android -->
                            <Button BackgroundColor="Transparent"
                                    BorderColor="Transparent"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"
                                    Command="{Binding OpenTrainingDayDetailCommand}" />
                        </Grid>
                    </Border>
                    
                    <!-- Card con el resumen semanal -->
                    <Border Grid.Row="2"
                            StrokeThickness="0"
                            IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                            BackgroundColor="{DynamicResource BackgroundPrimaryDark}">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>

                        <Grid>
                            <!-- Contenido del card -->
                            <Grid RowSpacing="10"
                                  Padding="12,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Title -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Column="0"
                                           VerticalOptions="Center"
                                           Text="Resumen de la semana"
                                           Style="{StaticResource label-h2-white}" />

                                    <Image Grid.Column="1"
                                           VerticalOptions="Center"
                                           Source="arrow_icon_white.png"
                                           MaximumHeightRequest="20"
                                           MaximumWidthRequest="20"/>
                                </Grid>

                                <!-- Box view -->
                                <BoxView Grid.Row="1"
                                         HeightRequest="4"
                                         CornerRadius="2"
                                         Color="{DynamicResource QuaternaryColor}"
                                         HorizontalOptions="Fill"/>

                                <!-- Week resume -->
                                <Label Grid.Row="2">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Entrenamientos "
                                                  Style="{StaticResource label-p-white}" />
                                            <Span Text="{Binding TrainingDayDto.DayNumber}"
                                                  Style="{StaticResource label-p-white}" />
                                            <Span Text="/"
                                                  Style="{StaticResource label-p-white}" />
                                            <Span Text="{Binding Routine.TrainingDays}"
                                                  Style="{StaticResource label-p-white}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>

                            <!-- Botón transparente superpuesto — ripple nativo Android -->
                            <Button BackgroundColor="Transparent"
                                    BorderColor="Transparent"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"
                                    Command="{Binding GoToWeeklySummaryCommand}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" 
                        IsEnabled="{Binding DoesntHaveRoutine}"
                            IsVisible="{Binding DoesntHaveRoutine}"
                            StrokeThickness="0"
                            Stroke="{DynamicResource BackgroundPrimaryLight}"
                            BackgroundColor="{DynamicResource BackgroundPrimaryDark}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Barra degradado izquierda -->
                            <Border Grid.Column="0"
                                StrokeThickness="0"
                                Background="{DynamicResource CardPremiumYellowGradientColor}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8,0,8,0"/>
                                </Border.StrokeShape>
                            </Border>

                            <!-- Contenido -->
                            <Grid Grid.Column="1"
                                  Padding="12,14"
                                  RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0"
                               Text="¿Todavía sin rutina? 💪"
                               Style="{DynamicResource label-h2-white}"/>

                                <Label Grid.Row="1"
                               Text="¿A qué estás esperando? Genera tu plan personalizado ahora y empieza a entrenar."
                               Style="{DynamicResource label-p-white}"
                               Opacity="0.7"
                               LineBreakMode="WordWrap"/>

                                <Button Grid.Row="2"
                                    Text="Generar mi rutina"
                                    Style="{DynamicResource ButtonBold-XL-dark-yellow}"
                                    HorizontalOptions="Start"
                                    FontSize="14"
                                    Command="{Binding GoToPlanCommand}"/>
                            </Grid>
                        </Grid>
                    </Border>
                    
                </Grid>
            </ScrollView>

            <!-- Registrar entrenamiento -->
            <Button Grid.Row="2"
                Text="{Binding ButtonContent}"
                Style="{DynamicResource ButtonBold-XL-dark-white}"
                CornerRadius="6"
                BorderColor="{DynamicResource BorderButtonLightColor}"
                BorderWidth="0.25"
                VerticalOptions="End"
                IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                Command="{Binding GoToChatViewCommand}"/>
        </Grid>

        <!--  Nav Menu -->
        <views:HomeFooterView Grid.Row="2" />

        <!-- Loading overlay encima de todo -->
        <components:LoadingOverlay
            Grid.RowSpan="3"
            IsLoading="{Binding IsLoading}"
            Message="{Binding StatusMessage}" />
    </Grid>
</ContentPage>
