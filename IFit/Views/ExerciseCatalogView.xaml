<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             xmlns:components="clr-namespace:IFit.Views.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:dtos="clr-namespace:IFit.Models.Dtos.Exercise"
             x:Class="IFit.Views.ExerciseCatalogView"
             x:Name="ExerciseCatalogPage"
             Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <ContentPage.BindingContext>
        <vm:ExerciseCatalogViewModel />
    </ContentPage.BindingContext>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Loading Overlay: solo para transiciones de navegación -->
        <components:LoadingOverlay Grid.RowSpan="5"
                                   IsLoading="{Binding IsNavigating}"
                                   Message="{Binding StatusMessage}"
                                   ZIndex="999" />

        <!-- Row 0: Header -->
        <Grid Grid.Row="0"
              Padding="20,50,20,15"
              ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ImageButton Grid.Column="0"
                         Source="arrow_icon_white.png"
                         HeightRequest="20"
                         WidthRequest="20"
                         VerticalOptions="Center"
                         Command="{Binding GoToHomeCommand}"
                         Rotation="180" />

            <HorizontalStackLayout Grid.Column="1"
                                   HorizontalOptions="Start"
                                   VerticalOptions="Center">
                <Label Text="Catálogo de "
                       Style="{StaticResource label-h1-white}" />
                <Label Text="Ejercicios"
                       Style="{StaticResource label-h1-yellow}" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Row 1: Barra de búsqueda -->
        <Grid Grid.Row="1"
              Margin="15,0,15,12"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8">

            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource BackgroundPrimaryLight}"
                    StrokeThickness="0"
                    Padding="12,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Entry Text="{Binding SearchText}"
                       Placeholder="Buscar por músculo, ej: pecho"
                       PlaceholderColor="{StaticResource BackgroundSecondaryDark}"
                       TextColor="{StaticResource BackgroundPrimaryDark}"
                       BackgroundColor="Transparent"
                       ReturnType="Search"
                       ReturnCommand="{Binding SearchCommand}"
                       ClearButtonVisibility="WhileEditing" />
            </Border>

            <Button Grid.Column="1"
                    Text="Buscar"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource ButtonBold-XL-yellow}"
                    FontSize="12"
                    Padding="15,0"
                    VerticalOptions="Center"
                    CornerRadius="{StaticResource CornerRadiusRectangle}" />
        </Grid>

        <!-- Row 2: Indicador inline de carga de datos (no bloquea la lista) -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsLoadingData}"
                           IsVisible="{Binding IsLoadingData}"
                           Color="{StaticResource TertiaryColor}"
                           HorizontalOptions="Center"
                           Margin="0,4" />

        <!-- Row 3: Listado de ejercicios -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Exercises}"
                        SelectionMode="None"
                        ItemSizingStrategy="MeasureFirstItem"
                        RemainingItemsThreshold="4"
                        RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                        Margin="15,4,15,8">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8"
                                     Padding="30"
                                     IsVisible="{Binding IsEmpty}">
                    <Label Text="Sin resultados"
                           Style="{StaticResource label-h2-white}"
                           HorizontalTextAlignment="Center"
                           Opacity="0.7" />
                    <Label Text="Prueba con otro término de búsqueda"
                           Style="{StaticResource label-p-white}"
                           HorizontalTextAlignment="Center"
                           Opacity="0.5" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dtos:ExerciseSummaryDto">
                    <Border Margin="0,0,0,8"
                            BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                            StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={x:Reference ExerciseCatalogPage}, Path=BindingContext.OpenDetailCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>

                        <Grid Padding="12,10" RowSpacing="5" RowDefinitions="Auto,Auto,Auto">

                            <!-- Nombre -->
                            <Label Grid.Row="0"
                                   Text="{Binding Name}"
                                   Style="{StaticResource label-h2-white}"
                                   LineBreakMode="WordWrap" />

                            <!-- Badges: Categoría · Nivel · Equipamiento -->
                            <HorizontalStackLayout Grid.Row="1" Spacing="6" Margin="0,2,0,0">

                                <Border BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                                        StrokeThickness="0"
                                        Padding="8,3">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Category}"
                                           TextColor="{StaticResource TextSecondaryColorLight}"
                                           FontSize="11"
                                           FontFamily="Montserrat-Medium" />
                                </Border>

                                <Border BackgroundColor="{StaticResource TertiaryColor}"
                                        StrokeThickness="0"
                                        Padding="8,3">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Level}"
                                           TextColor="{StaticResource BackgroundPrimaryDark}"
                                           FontSize="11"
                                           FontFamily="Montserrat-Medium" />
                                </Border>

                                <Border BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                                        StrokeThickness="0"
                                        Padding="8,3">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Equipment}"
                                           TextColor="{StaticResource TextPrimaryColorLight}"
                                           FontSize="11"
                                           FontFamily="Montserrat-Medium" />
                                </Border>

                            </HorizontalStackLayout>

                            <!-- Músculos principales -->
                            <Label Grid.Row="2"
                                   LineBreakMode="TailTruncation"
                                   Opacity="0.65">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Músculos: "
                                              TextColor="{StaticResource TextSecondaryColorLight}"
                                              FontFamily="Montserrat-Medium"
                                              FontSize="12" />
                                        <Span Text="{Binding PrimaryMuscles[0]}"
                                              TextColor="{StaticResource TextPrimaryColorLight}"
                                              FontFamily="Montserrat-Medium"
                                              FontSize="12" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Row 4: Footer -->
        <Button Grid.Row="4"
                Text="Crear rutina"
                Command="{Binding GoToRoutineBuilderCommand}"
                Style="{StaticResource ButtonBold-XL-dark-yellow}"
                CornerRadius="{StaticResource CornerRadiusRectangle}"
                VerticalOptions="Center"
                Margin="15,8,15,20" />
    </Grid>
</ContentPage>
