<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IFit.ViewModels"
             x:Class="IFit.Views.CommunityView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundPrimaryDark}">

    <ContentPage.BindingContext>
        <vm:CommunityViewModel />
    </ContentPage.BindingContext>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Grid Grid.Row="0"
              Background="{StaticResource CardPremiumYellowGradientColor}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Navbar: flecha izquierda + logo centrado -->
            <Grid Grid.Row="0" Margin="15,50,15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        BackgroundColor="Transparent"
                        ImageSource="arrow.png"
                        Command="{Binding GoToHomeCommand}" />
                <Image Grid.Column="0"
                       Grid.ColumnSpan="2"
                       Source="ifit_logo_white.png"
                       HeightRequest="20"
                       WidthRequest="120"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Grid>

            <!-- Eyebrow + título + subtítulo -->
            <VerticalStackLayout Grid.Row="1"
                                 Margin="15,8,15,20"
                                 Spacing="6">
                <Label Text="COMUNIDAD"
                       FontSize="11"
                       CharacterSpacing="2"
                       Opacity="0.7"
                       Style="{StaticResource label-p-white}" />
                <Label Text="Comparte tu progreso"
                       Style="{StaticResource label-Title-white}" />
                <Label Text="Forma parte de algo más grande y comparte tu experiencia fitness con el mundo."
                       Style="{StaticResource label-p-white}"
                       Opacity="0.85"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Grid>

        <!-- ── Body ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Margin="15,12,15,0">

                <!-- Separador -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{StaticResource TextSecondaryColorLight}"
                         Margin="0,0,0,12" />

                <!-- Sección: Comunidad -->
                <Label Text="Comunidad IFit"
                       Style="{StaticResource label-h2-white}"
                       Margin="0,0,0,8" />

                <!-- Card hero: icono + título con acento amarillo + descripción -->
                <Border StrokeThickness="0"
                        Margin="0,0,0,16"
                        BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="14" Padding="12,20">

                        <!-- Icono en círculo con borde amarillo -->
                        <Border HeightRequest="72"
                                WidthRequest="72"
                                StrokeThickness="2"
                                Stroke="{StaticResource TertiaryColor}"
                                BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <Ellipse />
                            </Border.StrokeShape>
                            <Image Source="community_ifit_white.png"
                                   HeightRequest="36"
                                   WidthRequest="36"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- "Gracias por ser parte de IFit" con IFit en amarillo -->
                        <Label HorizontalTextAlignment="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Gracias por ser parte de "
                                          FontFamily="Montserrat-Bold"
                                          FontSize="18"
                                          TextColor="{StaticResource TextPrimaryColorLight}" />
                                    <Span Text="IFit"
                                          FontFamily="Montserrat-Bold"
                                          FontSize="18"
                                          TextColor="{StaticResource TertiaryColor}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{StaticResource TextSecondaryColorLight}"
                                 Opacity="0.15" />

                        <Label Text="Eres parte de una comunidad que apuesta por el fitness inteligente. Tu compromiso con la salud nos inspira a seguir mejorando IFit cada día."
                               Style="{StaticResource label-p-white}"
                               Opacity="0.8"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Sección: Comparte -->
                <Label Text="Comparte tu experiencia"
                       Style="{StaticResource label-h2-white}"
                       Margin="0,0,0,8" />

                <!-- Card con barra lateral amarilla -->
                <Border StrokeThickness="0"
                        Margin="0,0,0,16"
                        BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Barra lateral amarilla -->
                        <Border Grid.Column="0"
                                StrokeThickness="0"
                                Margin="0"
                                Background="{StaticResource CardPremiumYellowGradientColor}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8,0,8,0" />
                            </Border.StrokeShape>
                        </Border>

                        <!-- Contenido -->
                        <VerticalStackLayout Grid.Column="1"
                                             Padding="12,14"
                                             Spacing="6">
                            <Label Text="¿Quieres compartirlo?"
                                   Style="{StaticResource label-h3-white}" />
                            <Label Text="Si IFit te está ayudando a entrenar mejor, cuéntaselo a tus contactos o publícalo en tus redes sociales. Pulsa el botón de abajo y elige dónde compartirlo."
                                   Style="{StaticResource label-p-white}"
                                   Opacity="0.7"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── CTA fijo ── -->
        <Grid Grid.Row="2" Margin="15">
            <Button Text="Compartir información"
                    Style="{StaticResource ButtonBold-XL-yellow}"
                    CornerRadius="{StaticResource CornerRadiusRectangle}"
                    Command="{Binding ShareCommand}" />
        </Grid>

    </Grid>
</ContentPage>
