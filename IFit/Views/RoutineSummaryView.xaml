<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="IFit.Views.RoutineSummaryView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:IFit.Models.Dtos.AI"
    xmlns:viewModels="clr-namespace:IFit.ViewModels"
    Title="Rutina Personalizada"
    x:DataType="viewModels:RoutineSummaryViewModel"
    BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
    Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <viewModels:RoutineSummaryViewModel />
    </ContentPage.BindingContext>

    <Grid Margin="15" RowSpacing="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header - Row 0  -->
        <Grid
            Grid.Row="0"
            Padding="15"
            HorizontalOptions="Fill">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Go Back  -->
            <Button
                Grid.Column="0"
                BackgroundColor="Transparent"
                Clicked="onCancelClicked"
                HorizontalOptions="Center"
                ImageSource="arrow.png"
                VerticalOptions="Center" />

            <!--  Center line  -->
            <Border
                Grid.Column="1"
                BackgroundColor="{StaticResource TextSecondaryColorLight}"
                HeightRequest="1"
                HorizontalOptions="Center"
                StrokeThickness="0"
                VerticalOptions="Center"
                WidthRequest="120" />

            <!--  Cancel button  -->
            <Button
                Grid.Column="2"
                BackgroundColor="Transparent"
                Clicked="onCancelClicked"
                HorizontalOptions="Center"
                ImageSource="cancel.svg"
                VerticalOptions="Center" />
        </Grid>

        <VerticalStackLayout Grid.Row="1">
            <!--  Título principal  -->
            <Label
                FontSize="28"
                HorizontalTextAlignment="Center"
                Style="{StaticResource label-h1-white}"
                Text="Tú rutina personalizada" />

            <!--  Mensaje del coach IA  -->
            <Label Style="{StaticResource label-p-white}" Text="{Binding MessageAI}" />


            <!--  Título "Rutina"  -->
            <Label Style="{StaticResource label-h1-yellow}" Text="Rutina" />
        </VerticalStackLayout>

        <!--  Scroll horizontal de días de entrenamiento  -->
        <ScrollView Grid.Row="2" Orientation="Horizontal">
            <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Routine.Days}" Spacing="15">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:TrainingDayDto">
                        <!--  Card de cada día  -->
                        <Border
                            Margin="0,0,0,15"
                            BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                            Stroke="{DynamicResource BackgroundPrimaryLight}"
                            StrokeThickness="2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                            </Border.StrokeShape>

                            <Border.Shadow>
                                <Shadow
                                    Brush="{DynamicResource BackgroundPrimaryLight}"
                                    Opacity="0.35"
                                    Radius="{DynamicResource CornerRadiusRectangle}" />
                            </Border.Shadow>

                            <Grid Padding="15" RowDefinitions="Auto,Auto,*,Auto">

                                <!--  Título del día  -->
                                <Label
                                    Grid.Row="0"
                                    Margin="0,0,0,10"
                                    FontAttributes="Bold"
                                    FontSize="20"
                                    Text="{Binding DayName}"
                                    />

                                <!--  Descripción del día  -->
                                <Label
                                    Grid.Row="1"
                                    Margin="0,0,0,15"
                                    FontSize="14"
                                    LineHeight="1.3"
                                    Text="{Binding Description}"
                                    TextColor="#cccccc" />

                                <!--  Lista de ejercicios  -->
                                <ScrollView Grid.Row="2">
                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Exercises}" Spacing="8">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:ExerciseDto">
                                                <Frame
                                                    Margin="0,0,0,5"
                                                    Padding="10"
                                                    BackgroundColor="#1a1a2e"
                                                    BorderColor="Transparent"
                                                    CornerRadius="8">
                                                    <VerticalStackLayout Spacing="4">
                                                        <Label
                                                            FontAttributes="Bold"
                                                            FontSize="14"
                                                            TextColor="White">
                                                            <Label.FormattedText>
                                                                <FormattedString>
                                                                    <Span Text="{Binding ExerciseName}" />
                                                                </FormattedString>
                                                            </Label.FormattedText>
                                                        </Label>
                                                        <Label FontSize="12" TextColor="#aaaaaa">
                                                            <Label.FormattedText>
                                                                <FormattedString>
                                                                    <Span Text="{Binding Sets, StringFormat='{0} series'}" />
                                                                    <Span Text=" × " />
                                                                    <Span Text="{Binding Reps, StringFormat='{0} reps'}" />
                                                                </FormattedString>
                                                            </Label.FormattedText>
                                                        </Label>
                                                        <!--
                                                            Label Text="{Binding RestSeconds, StringFormat='Descanso: {0}s'}"
                                                            FontSize="11"
                                                            TextColor="#888888"
                                                            IsVisible="{Binding RestSeconds, Converter={StaticResource IntToBoolConverter}}"/>
                                                        -->
                                                    </VerticalStackLayout>
                                                </Frame>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </ScrollView>

                                <!--  Logo iFit en la esquina inferior  -->
                                <Label
                                    Grid.Row="3"
                                    Margin="0,10,0,0"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    HorizontalOptions="End"
                                    Text="iFit"
                                    TextColor="#f39c12"
                                    VerticalOptions="End" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!--  Botones de acción  -->
        <Grid
            Grid.Row="3"
            Margin="0,20,0,20"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="10">

            <!--  Botón Probar de nuevo  -->
            <Button
                Grid.Column="0"
                Command="{Binding TryAgainCommand}"
                CornerRadius="{DynamicResource CornerRadiusRectangle}"
                HorizontalOptions="Fill"
                Style="{DynamicResource ButtonBold-XL-dark-yellow}"
                Text="Probar de nuevo" />

            <!--  Botón Me gusta  -->
            <Button
                Grid.Column="1"
                Command="{Binding SaveRoutineCommand}"
                CornerRadius="{DynamicResource CornerRadiusRectangle}"
                Style="{DynamicResource ButtonBold-XL-yellow}"
                Text="¡Me gusta!" />
        </Grid>
    </Grid>
</ContentPage>
