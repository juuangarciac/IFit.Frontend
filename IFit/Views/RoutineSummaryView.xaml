<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="IFit.Views.RoutineSummaryView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:IFit.Models.Dtos.AI"
    xmlns:viewModels="clr-namespace:IFit.ViewModels"
    xmlns:components="clr-namespace:IFit.Views.Components"
    x:DataType="viewModels:RoutineSummaryViewModel"
    BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
    Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <viewModels:RoutineSummaryViewModel />
    </ContentPage.BindingContext>

    <Grid Margin="15" >
        <!-- Loading Overlay -->
        <components:LoadingOverlay IsLoading="{Binding IsLoading}"
                            Message="{Binding  StatusMessage}"
                             ZIndex="999"/>
        
        <!-- content -->
        <Grid RowSpacing="10"
              RowDefinitions="Auto,Auto,Auto,*,Auto">

            <!-- Row 0: Header (back + línea decorativa + cancel) -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Go Back -->
                <Button Grid.Column="0"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                ImageSource="arrow.png"
                Clicked="onCancelClicked" />

                <!-- Línea decorativa central -->
                <BoxView Grid.Column="1"
                         BackgroundColor="{StaticResource TextSecondaryColorLight}"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"
                         WidthRequest="120"
                         HeightRequest="1" />

                <!-- Cancel -->
                <Button Grid.Column="2"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                ImageSource="cancel.svg"
                Clicked="onCancelClicked" />
            </Grid>

            <!-- Row 1: Título principal -->
            <VerticalStackLayout Grid.Row="1" Spacing="2">
                <Label HorizontalTextAlignment="Center"
                       Style="{StaticResource label-Title-white}"
                       Text="Tú rutina personalizada" />
                <Label Style="{StaticResource label-h1-yellow}"
               HorizontalTextAlignment="Center"
               Text="Rutina" />
            </VerticalStackLayout>

            <!-- Row 2: Indicador de día (solo visible si hay más de un día) -->
            <HorizontalStackLayout Grid.Row="2"
                           HorizontalOptions="Center">

                <!-- Botón anterior (overlay izquierda) -->
                <Button Command="{Binding GoToPreviousDayCommand}"
                IsVisible="{Binding HasMultipleDays}"
                BackgroundColor="Transparent"
                Text="◀"
                TextColor="{StaticResource TertiaryColor}"
                FontSize="26"
                HorizontalOptions="Start"
                VerticalOptions="Center"
                WidthRequest="26"
                Padding="0" />


                <Label 
           Text="{Binding DayIndicatorText}"
           IsVisible="{Binding HasMultipleDays}"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           Style="{StaticResource label-p-white}"
           Opacity="0.65" />

                <!-- Botón siguiente (overlay derecha) -->
                <Button Command="{Binding GoToNextDayCommand}"
                IsVisible="{Binding HasMultipleDays}"
                BackgroundColor="Transparent"
                Text="▶"
                TextColor="{StaticResource TertiaryColor}"
                FontSize="26"
                HorizontalOptions="End"
                VerticalOptions="Center"
                WidthRequest="26"
                Padding="0" />

            </HorizontalStackLayout>

            <!-- Row 3: Tarjeta del día actual (ancho completo) + botones nav en overlay -->
            <Grid Grid.Row="3">

                <!-- Tarjeta del día actual -->
                <Border StrokeThickness="0"
                        BackgroundColor="{DynamicResource BackgroundSecondaryDark}">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                    </Border.StrokeShape>

                    <Grid Padding="15"
                  RowSpacing="6"
                  RowDefinitions="Auto,Auto,Auto,*,Auto">

                        <!-- Nombre del día -->
                        <Label Grid.Row="0"
                       Style="{StaticResource label-h1-white}"
                       Text="{Binding CurrentDay.DayName}" />

                        <!-- Descripción -->
                        <Label Grid.Row="1"
                       Style="{StaticResource label-p-white}"
                       Text="{Binding CurrentDay.Description}"
                       LineBreakMode="WordWrap" />

                        <!-- Indicador de scroll (solo si hay más ejercicios de los que caben) -->
                        <Label Grid.Row="2"
                               IsVisible="{Binding ShowScrollIndicator}"
                               Text="▼  desliza para ver todos los ejercicios"
                               Style="{StaticResource navbar-p-white}"
                               TextColor="{StaticResource TertiaryColor}"
                               Opacity="0.85"
                               Margin="0,2,0,2" />

                        <!-- Lista de ejercicios con scroll vertical -->
                        <ScrollView Grid.Row="3" Orientation="Vertical">
                            <VerticalStackLayout Margin="0,4,0,0"
                                         BindableLayout.ItemsSource="{Binding CurrentDay.Exercises}"
                                         Spacing="14">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:ExerciseDto">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding ExerciseName}"
                                                   Style="{StaticResource label-h3-white}"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding Notes}"
                                           Style="{StaticResource label-p-white}"
                                           LineBreakMode="WordWrap" />
                                            <Label Style="{StaticResource label-p-white}"
                                           Opacity="0.75">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding Sets, StringFormat='{0} series'}"
                                                      Style="{StaticResource label-p-white}" />
                                                        <Span Text=" × "
                                                      Style="{StaticResource label-p-white}" />
                                                        <Span Text="{Binding Reps, StringFormat='{0} reps'}"
                                                      Style="{StaticResource label-p-white}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </ScrollView>

                        <!-- Logo ifit anclado al pie de la tarjeta -->
                        <Image Grid.Row="4"
                       Margin="0,6,0,-15"
                       Source="ifit_logo_white.png"
                       HorizontalOptions="End"
                       VerticalOptions="End"
                       HeightRequest="50"
                       WidthRequest="50" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 4: Botones de acción -->
            <VerticalStackLayout Grid.Row="4"
                                 Margin="0,4,0,8"
                                 Spacing="10">

                <Button Command="{Binding TryAgainCommand}"
                        HorizontalOptions="Fill"
                        HeightRequest="52"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                        Style="{DynamicResource ButtonBold-XL-dark-white}"
                        Text="Probar de nuevo" />

                <Button Command="{Binding SaveRoutineCommand}"
                        HorizontalOptions="Fill"
                        HeightRequest="52"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                        Style="{DynamicResource ButtonBold-XL-yellow}"
                        Text="¡Me gusta!" />

            </VerticalStackLayout>
        </Grid>

        <!-- Overlay: nota para regenerar rutina -->
        <Grid IsVisible="{Binding ShowNoteInput}"
              BackgroundColor="#CC000000"
              ZIndex="998"
              Padding="24">

            <Border BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
                    VerticalOptions="Center"
                    Padding="24">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="20">

                    <Label Text="¿Qué quieres cambiar?"
                           Style="{StaticResource label-h1-white}"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Escribe una nota para que tu coach la tenga en cuenta al regenerar la rutina. Es opcional."
                           Style="{StaticResource label-p-white}"
                           HorizontalTextAlignment="Center"
                           Opacity="0.7" />

                    <Border Style="{StaticResource BorderRectangleWhite}"
                            Padding="12,8">
                        <Entry Text="{Binding UserNote}"
                               Placeholder="Ej: sin sentadillas, más ejercicios de pecho…"
                               PlaceholderColor="{DynamicResource TextSecondaryColorLight}"
                               TextColor="{StaticResource TextPrimaryColorLight}"
                               BackgroundColor="Transparent"
                               FontFamily="Montserrat-Medium"
                               FontSize="14" />
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Grid.Column="0"
                                Command="{Binding CancelTryAgainCommand}"
                                Text="Cancelar"
                                HeightRequest="48"
                                CornerRadius="{DynamicResource CornerRadiusRectangle}"
                                Style="{DynamicResource ButtonBold-XL-dark-white}" />

                        <Button Grid.Column="1"
                                Command="{Binding ConfirmTryAgainCommand}"
                                Text="Regenerar"
                                HeightRequest="48"
                                CornerRadius="{DynamicResource CornerRadiusRectangle}"
                                Style="{DynamicResource ButtonBold-XL-yellow}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
