<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="IFit.Views.RoutineSummaryView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:IFit.Models.Dtos.AI"
    xmlns:viewModels="clr-namespace:IFit.ViewModels"
    Title="Rutina Personalizada"
    x:DataType="viewModels:RoutineSummaryViewModel"
    BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
    Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <viewModels:RoutineSummaryViewModel />
    </ContentPage.BindingContext>

    <Grid Margin="15" RowSpacing="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header - Row 0 
        <Grid
            Grid.Row="0"
            Padding="15"
            HorizontalOptions="Fill">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

           
            <Button
                Grid.Column="0"
                BackgroundColor="Transparent"
                Clicked="onCancelClicked"
                HorizontalOptions="Center"
                ImageSource="arrow.png"
                VerticalOptions="Center" />

            
            <Border
                Grid.Column="1"
                BackgroundColor="{StaticResource TextSecondaryColorLight}"
                HeightRequest="1"
                HorizontalOptions="Center"
                StrokeThickness="0"
                VerticalOptions="Center"
                WidthRequest="120" />

           
            <Button
                Grid.Column="2"
                BackgroundColor="Transparent"
                Clicked="onCancelClicked"
                HorizontalOptions="Center"
                ImageSource="cancel.svg"
                VerticalOptions="Center" />
        </Grid>  -->

        <VerticalStackLayout Grid.Row="1">
            <!--  Título principal  -->
            <Label
                FontSize="28"
                HorizontalTextAlignment="Center"
                Style="{StaticResource label-h1-white}"
                Text="Tú rutina personalizada" />

            <!--  Título "Rutina"  -->
            <Label Style="{StaticResource label-h1-yellow}" Text="Rutina" />
            
            <!-- Informacion adicional - Mensaje del Entrenador -->
            <Label Style="{StaticResource label-p-white}"
                   Text="{Binding MessageAI}" />
            
        </VerticalStackLayout>

        <!--  Scroll horizontal de días de entrenamiento  -->
        <ScrollView Grid.Row="2" 
                    Orientation="Horizontal"
                    VerticalOptions="Fill">
            <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Routine.Days}" Spacing="15">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:TrainingDayDto">
                        <Border StrokeThickness="2"
                        Stroke="{DynamicResource BackgroundPrimaryLight}"
                        BackgroundColor="{DynamicResource PrimaryColorLightOpacity}"
                        WidthRequest="300">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="{DynamicResource CornerRadiusRectangle}" />
                            </Border.StrokeShape>

                            <Border.Shadow>
                                <Shadow Brush="{DynamicResource BackgroundPrimaryLight}"
                                Opacity="0.35"
                                Radius="{DynamicResource CornerRadiusRectangle}" />
                            </Border.Shadow>

                            <Grid Padding="15" 
                                  RowSpacing="5"
                                  RowDefinitions="Auto,Auto,*,Auto">

                                <Label Grid.Row="0"
                               Style="{StaticResource label-h1-white}"
                               Text="{Binding DayName}" />

                                <Label Grid.Row="1"
                               Style="{StaticResource label-p-white}"
                               Text="{Binding Description}" />

                                <VerticalStackLayout Grid.Row="2"
                                                     Margin="5"
                                                    BindableLayout.ItemsSource="{Binding Exercises}" Spacing="12">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ExerciseDto">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding ExerciseName}"
                                                       Style="{StaticResource label-h3-white}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"/>
                                                <Label Text="{Binding Notes}"
                                                       Style="{StaticResource label-p-white}"/> 
                                                <Label Style="{StaticResource label-p-white}" Opacity="0.75">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{Binding Sets, StringFormat='{0} series'}"
                                                                    Style="{StaticResource label-p-white}"/>
                                                            <Span Text=" × " Style="{StaticResource label-p-white}"/>
                                                            <Span Text="{Binding Reps, StringFormat='{0} reps'}"
                                                                    Style="{StaticResource label-p-white}"/>
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                                
                                <!-- Logo de ifit -->
                                <Image Grid.Row="3"
                                       Margin="0, 0, 0, -15"
                                        Source="ifit_logo_white.png"
                                        HorizontalOptions="End"
                                        VerticalOptions="End"
                                        HeightRequest="55"
                                        WidthRequest="55"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!--  Botones de acción  -->
        <Grid
            Grid.Row="3"
            Margin="0,20,0,20"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="10">

            <!--  Botón Probar de nuevo  -->
            <Button
                Grid.Column="0"
                Command="{Binding TryAgainCommand}"
                CornerRadius="{DynamicResource CornerRadiusRectangle}"
                HorizontalOptions="Fill"
                Style="{DynamicResource ButtonBold-XL-dark-yellow}"
                Text="Probar de nuevo" />

            <!--  Botón Me gusta  -->
            <Button
                Grid.Column="1"
                Command="{Binding SaveRoutineCommand}"
                CornerRadius="{DynamicResource CornerRadiusRectangle}"
                Style="{DynamicResource ButtonBold-XL-yellow}"
                Text="¡Me gusta!" />
        </Grid>
    </Grid>
</ContentPage>
