<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vmodels="clr-namespace:IFit.ViewModels"
             xmlns:dtos="clr-namespace:IFit.Models.Dtos.AI"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:components="clr-namespace:IFit.Views.Components"
x:Class="IFit.Views.WeeklySummaryView"
             Title="WeeklySummaryView"
             Shell.NavBarIsVisible="False">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>
    <ContentPage.BindingContext>
        <vmodels:WeeklySummaryViewModel />
    </ContentPage.BindingContext>

    <Grid BackgroundColor="{StaticResource BackgroundPrimaryDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="220" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Imagen de fondo -->
            <Image Grid.Row="0"
                   Grid.RowSpan="2"
                   Source="verificationpageimg.jpg"
                   Aspect="AspectFill" />

            <!-- Overlay gradiente oscuro para legibilidad -->
            <BoxView Grid.Row="0"
                     Grid.RowSpan="2">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#66000000" Offset="0.0" />
                        <GradientStop Color="#22000000" Offset="0.5" />
                        <GradientStop Color="#99000000" Offset="1.0" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <!-- Navbar -->
            <Grid Grid.Row="0" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        BackgroundColor="Transparent"
                        ImageSource="arrow.png"
                        Clicked="BackToHome" />
                <Image Grid.Column="0"
                       Grid.ColumnSpan="2"
                       Source="ifit_logo_white.png"
                       HeightRequest="20"
                       WidthRequest="120"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Grid>

            <!-- Títulos -->
            <VerticalStackLayout Grid.Row="1"
                                 Margin="15,0,15,20"
                                 Spacing="6"
                                 VerticalOptions="End">
                <Label Text="RESUMEN SEMANAL"
                       FontSize="11"
                       CharacterSpacing="2"
                       Opacity="0.7"
                       Style="{StaticResource label-p-white}" />
                <Label Text="Tu progreso esta semana"
                       Style="{StaticResource label-Title-white}" />
                <Label Text="A continuación te presentamos un resumen de tu progreso semanal"
                       Style="{StaticResource label-p-white}"
                       Opacity="0.8"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1"
                    Margin="0,10,0,0"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">

            <VerticalStackLayout Spacing="0" Margin="15,12,15,0">

                <!-- Separator -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{StaticResource TextSecondaryColorLight}"
                         Margin="0,0,0,12" />

                <!-- Stats -->
                <Grid ColumnSpacing="8" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" StrokeThickness="0"
                            BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <VerticalStackLayout Padding="6,10" Spacing="3" HorizontalOptions="Center">
                            <Label Text="{Binding SessionProgress}"
                                   FontFamily="Montserrat-Bold"
                                   FontSize="17"
                                   TextColor="{StaticResource TertiaryColor}"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="sesiones"
                                   Style="{StaticResource label-p-white}"
                                   FontSize="11"
                                   Opacity="0.6"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" StrokeThickness="0"
                            BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <VerticalStackLayout Padding="6,10" Spacing="3" HorizontalOptions="Center">
                            <Label Text="{Binding TotalExercises}"
                                   FontFamily="Montserrat-Bold"
                                   FontSize="17"
                                   TextColor="{StaticResource TertiaryColor}"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="ejercicios"
                                   Style="{StaticResource label-p-white}"
                                   FontSize="11"
                                   Opacity="0.6"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" StrokeThickness="0"
                            BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <VerticalStackLayout Padding="6,10" Spacing="3" HorizontalOptions="Center">
                            <Label Text="{Binding TotalSets}"
                                   FontFamily="Montserrat-Bold"
                                   FontSize="17"
                                   TextColor="{StaticResource TertiaryColor}"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="series"
                                   Style="{StaticResource label-p-white}"
                                   FontSize="11"
                                   Opacity="0.6"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="3" StrokeThickness="0"
                            BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <VerticalStackLayout Padding="6,10" Spacing="3" HorizontalOptions="Center">
                            <Label Text="{Binding EstimatedTime}"
                                   FontFamily="Montserrat-Bold"
                                   FontSize="17"
                                   TextColor="{StaticResource TertiaryColor}"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="tiempo est."
                                   Style="{StaticResource label-p-white}"
                                   FontSize="11"
                                   Opacity="0.6"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Gráfica ejercicios por sesión -->
                <Border StrokeThickness="0"
                        BackgroundColor="{StaticResource BackgroundSecondaryDark}"
                        Margin="0,0,0,16"
                        IsVisible="{Binding HasCompletedSessions}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="12,10" Spacing="6">
                        <Label Text="Ejercicios por sesión"
                               Style="{StaticResource label-h3-white}"
                               Opacity="0.7"/>
                        <GraphicsView Drawable="{Binding BarChart}"
                                      HeightRequest="160"
                                      BackgroundColor="Transparent"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Descripción -->
                <Label Text="Descripción"
                       Style="{StaticResource label-h2-white}"
                       Margin="0,0,0,8" />

                <Border StrokeThickness="0"
                        Margin="0,0,0,16"
                        BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="{Binding Routine.Description}"
                           Style="{StaticResource label-p-white}"
                           Padding="12,10" />
                </Border>

                <!-- Sesiones completadas -->
                <Label Text="Sesiones completadas"
                       Style="{StaticResource label-h2-white}"
                       Margin="0,0,0,8" />

                <CollectionView ItemsSource="{Binding CompletedSessions}"
                                SelectedItem="{Binding TrainingDayDto}"
                                SelectionMode="Single"
                                Margin="0,0,0,16">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dtos:TrainingDayDto">
                            <Border StrokeThickness="0"
                                    Margin="0,0,0,8">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource BackgroundSecondaryDark}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource BackgroundPrimaryDark}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Barra lateral verde (completada) -->
                                    <Border Grid.Column="0"
                                            StrokeThickness="0"
                                            Margin="0"
                                            Background="{DynamicResource CardPremiumGradientColor}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8,0,8,0"/>
                                        </Border.StrokeShape>
                                    </Border>

                                    <Grid Grid.Column="1"
                                          RowSpacing="4"
                                          Padding="12,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0"
                                                   Text="{Binding DayName}"
                                                   Style="{DynamicResource label-h2-white}"/>
                                            <Image Grid.Column="1"
                                                   VerticalOptions="Center"
                                                   Source="arrow_icon_white.png"
                                                   MaximumHeightRequest="20"
                                                   MaximumWidthRequest="20"/>
                                        </Grid>

                                        <Label Grid.Row="1"
                                               Text="{Binding Description}"
                                               Style="{DynamicResource label-p-white}"
                                               Opacity="0.7"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Sesiones pendientes -->
                <Label Text="Sesiones pendientes"
                       Style="{StaticResource label-h2-white}"
                       Margin="0,0,0,8" />

                <CollectionView ItemsSource="{Binding UncompletedSessions}"
                                SelectedItem="{Binding TrainingDayDto}"
                                SelectionMode="Single"
                                Margin="0,0,0,16">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dtos:TrainingDayDto">
                            <Border StrokeThickness="0"
                                    Margin="0,0,0,8">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource BackgroundSecondaryDark}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource BackgroundPrimaryDark}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Barra lateral naranja (pendiente) -->
                                    <Border Grid.Column="0"
                                            StrokeThickness="0"
                                            Margin="0"
                                            Background="{DynamicResource CardPremiumOrangeGradientColor}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8,0,8,0"/>
                                        </Border.StrokeShape>
                                    </Border>

                                    <Grid Grid.Column="1"
                                          RowSpacing="4"
                                          Padding="12,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0"
                                                   Text="{Binding DayName}"
                                                   Style="{DynamicResource label-h2-white}"/>
                                            <Image Grid.Column="1"
                                                   VerticalOptions="Center"
                                                   Source="arrow_icon_white.png"
                                                   MaximumHeightRequest="20"
                                                   MaximumWidthRequest="20"/>
                                        </Grid>

                                        <Label Grid.Row="1"
                                               Text="{Binding Description}"
                                               Style="{DynamicResource label-p-white}"
                                               Opacity="0.7"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading overlay encima de todo -->
        <components:LoadingOverlay
            Grid.RowSpan="2"
            IsLoading="{Binding IsLoading}"
            Message="{Binding StatusMessage}" />
    </Grid>
</ContentPage>
