<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IFit.Views.SignUpPage"
             Title="SignUpPage"
             Shell.NavBarIsVisible="False">
    <ScrollView BackgroundColor="{StaticResource BackgroundPrimaryDark}">
        <!-- Main Grid -->
        <Grid Style="{StaticResource BasicGrid}"
              HorizontalOptions="Fill"
              VerticalOptions="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Title -->
            <Label Grid.Row="0"
                   Text="Registrarme en IFit" 
                   TextColor="{StaticResource TextPrimaryColorLight}"
                   FontFamily="MontserratBold"
                   FontSize="20"
                   />

            <!-- SignIn with Ifit account -->
            <Grid Grid.Row="1"
                  RowSpacing="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <!-- Name Entry -->
                <Border Grid.Row="0"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource BackgroundPrimaryLight}"
                        Padding="5, 5, 5, 5"
                        HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    
                    <Border.Content>
                        <Entry Placeholder="Introduzca su nombre"
                               PlaceholderColor="{StaticResource TextPrimaryColorDark}"
                               FontFamily="Montserrat-Regular"
                               FontSize="16"
                               BackgroundColor="Transparent"
                       />
                    </Border.Content>
                </Border>
                
                <!-- Email Entry -->
                <Border Grid.Row="1"
                         StrokeThickness="0"
                         BackgroundColor="{StaticResource BackgroundPrimaryLight}"
                         Padding="5, 5, 5, 5"
                         HorizontalOptions="Fill">  
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Border.Content>
                        <Entry Placeholder="Introduzca su email"
                                PlaceholderColor="{StaticResource TextPrimaryColorDark}"
                                FontFamily="Montserrat-Regular"
                                FontSize="16"
                                BackgroundColor="Transparent" />
                    </Border.Content>
                </Border>
                
                <!-- Password Entry -->
                <Border Grid.Row="2"
                         StrokeThickness="0"
                         BackgroundColor="{StaticResource BackgroundPrimaryLight}"
                         Padding="5, 5, 5, 5"
                         HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Border.Content>
                        <Entry Placeholder="Introduzca su contraseña"
                                PlaceholderColor="{StaticResource TextPrimaryColorDark}"
                                FontFamily="Montserrat-Regular"
                                FontSize="16"
                                BackgroundColor="Transparent" />
                    </Border.Content>
                </Border>
                
                <!-- Terms and condition -->
                <Label Grid.Row="3"
       HorizontalTextAlignment="Center"
       VerticalTextAlignment="Center"
       HorizontalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Al crear una cuenta en IFit, aceptas nuestros "
                  FontFamily="Montserrat-Light"
                  FontSize="14"
                  TextColor="{StaticResource TextSecondaryColorLight}" />
                            <Span Text="Términos y Condiciones"
                  FontFamily="Montserrat-Light"
                  FontSize="14"
                  TextColor="{StaticResource TextSecondaryColorLight}"
                  TextDecorations="Underline" />
                            <Span Text=" y la "
                  FontFamily="Montserrat-Light"
                  FontSize="14"
                  TextColor="{StaticResource TextSecondaryColorLight}" />
                            <Span Text="Política de Privacidad"
                  FontFamily="Montserrat-Light"
                  FontSize="14"
                  TextColor="{StaticResource TextSecondaryColorLight}"
                  TextDecorations="Underline" />
                            <Span Text="."
                  FontFamily="Montserrat-Light"
                  FontSize="14"
                  TextColor="{StaticResource TextSecondaryColorLight}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

            </Grid>
            
            <!-- SignIn with Third party services -->
            <Grid Grid.Row="2">
                
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>