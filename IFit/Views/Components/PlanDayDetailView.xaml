<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:IFit.Models.Dtos.AI"
             x:Class="IFit.Views.Components.PlanDayDetailView"
             x:Name="this"
             BackgroundColor="Transparent">

    <Border BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
            StrokeThickness="0"
            Margin="0,60,0,0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="24,24,0,0" />
        </Border.StrokeShape>

        <Grid RowDefinitions="Auto,*">

            <!-- Handle + Header -->
            <VerticalStackLayout Grid.Row="0" Spacing="0">

                <!-- Handle -->
                <BoxView WidthRequest="40"
                         HeightRequest="4"
                         CornerRadius="2"
                         BackgroundColor="{StaticResource TextSecondaryColorLight}"
                         Opacity="0.4"
                         HorizontalOptions="Center"
                         Margin="0,12,0,0"/>

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto"
                      Margin="20,16,16,0">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="{Binding TrainingDayDto.DayName, Source={x:Reference this}}"
                               Style="{DynamicResource label-Title-white}"
                               FontSize="22"/>
                        <Label Text="{Binding TrainingDayDto.Description, Source={x:Reference this}}"
                               Style="{DynamicResource label-p-white}"
                               Opacity="0.7"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            BackgroundColor="Transparent"
                            ImageSource="cancel.svg"
                            VerticalOptions="Start"
                            Clicked="onCancelClicked" />
                </Grid>

                <!-- Separador doble -->
                <BoxView HeightRequest="2"
                         BackgroundColor="{StaticResource TertiaryColor}"
                         Margin="20,16,20,0"/>
                <BoxView HeightRequest="1"
                         BackgroundColor="{StaticResource TextSecondaryColorLight}"
                         Opacity="0.15"
                         Margin="20,6,20,0"/>
            </VerticalStackLayout>

            <!-- Ejercicios scrolleables -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="15,12,15,40" Spacing="0">
                    <BindableLayout.ItemsSource>
                        <Binding Path="TrainingDayDto.Exercises"
                                 Source="{x:Reference this}"/>
                    </BindableLayout.ItemsSource>
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:ExerciseDto">
                            <Border StrokeThickness="0"
                                    Margin="0,0,0,8"
                                    BackgroundColor="{StaticResource BackgroundSecondaryDark}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>

                                <!-- Contenido ejercicio -->
                                <VerticalStackLayout Padding="12,10"
                                                     Spacing="4">
                                    <Label Text="{Binding ExerciseName}"
                                           Style="{StaticResource label-h2-white}"/>
                                    <Label Text="{Binding Notes}"
                                           Style="{StaticResource label-p-white}"
                                           Opacity="0.7"
                                           LineBreakMode="WordWrap"/>

                                    <!-- Badge series × reps -->
                                    <Border BackgroundColor="{StaticResource BackgroundPrimaryDark}"
                                            StrokeThickness="0"
                                            Padding="10,4"
                                            Margin="0,4,0,0"
                                            HorizontalOptions="Start">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="20"/>
                                        </Border.StrokeShape>
                                        <Label>
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Sets}"
                                                          FontFamily="Montserrat-Bold"
                                                          TextColor="{StaticResource TertiaryColor}"/>
                                                    <Span Text=" series × "/>
                                                    <Span Text="{Binding Reps}"
                                                          FontFamily="Montserrat-Bold"
                                                          TextColor="{StaticResource TertiaryColor}"/>
                                                    <Span Text=" reps"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Border>
</ContentView>
