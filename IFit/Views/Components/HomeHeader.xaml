<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:cal="clr-namespace:Plugin.Maui.Calendar.Controls;assembly=Plugin.Maui.Calendar"
             xmlns:vm="clr-namespace:IFit.ViewModels.Templates"
             x:Class="IFit.Views.Templates.HomeHeader">
    <ContentView.BindingContext>
        <vm:HomeHeaderViewModel />
    </ContentView.BindingContext>
    <!-- Header -->
    <Border 
         BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
         Stroke="{DynamicResource BackgroundPrimaryDark}"
         StrokeThickness="0"
         StrokeShape="RoundRectangle 0, 0, 10, 10">
        <Border.Shadow>
            <Shadow Opacity="0.4"
                 Brush="Black"
                 Offset="5, 5" />
        </Border.Shadow>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Profile/Notif/Icon/Calendar -->
            <Grid Grid.Row="0"
                    Margin="10, 15, 15, 0"
                    ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left side: Profile + Notif -->
                <StackLayout Grid.Column="0" 
                 Orientation="Horizontal" 
                 Spacing="20"
                 HorizontalOptions="Start">
                    <!-- Profile Icon -->
                    <Grid>
                        <Image Source="profile_icon_white.png"
                               Style="{DynamicResource navbar_image}"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToProfileCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                    <!-- Notif Icon -->
                    <Image Source="notification_icon_white.png"
                           Style="{DynamicResource navbar_image}"/>
                            </StackLayout>

                <!-- Center: ifit logo -->
                <Image Grid.Column="1"
                       Source="ifit_logo_white.png"
                       HeightRequest="20"
                       WidthRequest="120"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

                <!-- Right side: Calendar -->
                <Image Grid.Column="2"
                       Source="calendar_icon_white.png"
                       Style="{DynamicResource navbar_image}"
                       HorizontalOptions="End"/>
            </Grid>

            <!-- Calendar -->
            <cal:Calendar Grid.Row="1"
                   Style="{StaticResource calendar_ifit_style}" 
                   CalendarLayout="{Binding SelectedLayout}">
            </cal:Calendar>

            <!--Expand Calendar Scroll -->
            <BoxView Grid.Row="2"
                     Color="{DynamicResource BackgroundPrimaryLight}"
                     HeightRequest="2"
                     WidthRequest="40"
                     CornerRadius="1"
                     HorizontalOptions="Center"
                     VerticalOptions="Center">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ExpandCalendarCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>

        </Grid>
    </Border>
</ContentView>