<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IFit.Views.Templates.HomeFooterView" >
    <Border BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
        Stroke="{DynamicResource BackgroundPrimaryDark}"
        StrokeThickness="0"
        StrokeShape="RoundRectangle 10, 10, 0, 0">
        <Border.Shadow>
            <Shadow Opacity="0.4"
                     Brush="Black"
                     Offset="5, 5" />
        </Border.Shadow>
        <Grid BackgroundColor="{DynamicResource BackgroundPrimaryDark}"
              HorizontalOptions="Fill"
              Margin="0, 5, 0, 5"
              Padding="0, 5, 0, 5">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Home icon -->
            <Grid Grid.Column="0"
              RowDefinitions="Auto, Auto"
              HorizontalOptions="Center"
              VerticalOptions="Center">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToHomeClicked}" />
                </Grid.GestureRecognizers>
                <Image  Grid.Row="0"
                    Source="home_ifit_white.png"
                    Style="{DynamicResource navbar_image}" />
                <Label  Grid.Row="1"
                    Text="Hoy"
                    Style="{DynamicResource navbar-p-white}" />
            </Grid>

            <!-- Plan icon -->
            <Grid Grid.Column="1"
              RowDefinitions="Auto, Auto"
              HorizontalOptions="Center"
              VerticalOptions="Center">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToPlanClicked}" />
                </Grid.GestureRecognizers>
                <Image  Grid.Row="0"
                    Source="plan_ifit_white.png"
                    Style="{DynamicResource navbar_image}" />
                <Label  Grid.Row="1"
                    Text="Plan"
                    Style="{DynamicResource navbar-p-white}" />
            </Grid>

            <!-- Workouts icon -->
            <Grid Grid.Column="2"
              RowDefinitions="Auto, Auto"
              HorizontalOptions="Center"
              VerticalOptions="Center">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToWorkoutsClicked}" />
                </Grid.GestureRecognizers>
                <Image  Grid.Row="0"
                    Source="workouts_ifit_white.png"
                    Style="{DynamicResource navbar_image}" />
                <Label  Grid.Row="1"
                    Text="Actividades"
                    Style="{DynamicResource navbar-p-white}" />
            </Grid>

            <!-- Community icon -->
            <Grid Grid.Column="3"
              RowDefinitions="Auto, Auto"
              HorizontalOptions="Center"
              VerticalOptions="Center">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToCommunityClicked}" />
                </Grid.GestureRecognizers>
                <Image  Grid.Row="0"
                    Source="community_ifit_white.png"
                    Style="{DynamicResource navbar_image}" />
                <Label  Grid.Row="1"
                    Text="Comunidad"
                    Style="{DynamicResource navbar-p-white}"
                    LineBreakMode="TailTruncation"/>
            </Grid>

            <!-- Help -->
            <Grid Grid.Column="4"
              RowDefinitions="Auto, Auto"
              HorizontalOptions="Center"
              VerticalOptions="Center">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToHelpClicked}" />
                </Grid.GestureRecognizers>
                <Image  Grid.Row="0"
                    Source="help_ifit_white.png"
                    Style="{DynamicResource navbar_image}" />
                <Label  Grid.Row="1"
                    Text="Ayuda"
                    Style="{DynamicResource navbar-p-white}"
                    LineBreakMode="TailTruncation"/>
            </Grid>

        </Grid>
    </Border>
</ContentView>